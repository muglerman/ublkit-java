<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>{{ doc.serie }}-{{ doc.correlativo }} · Factura Electrónica</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap');
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root {
    --ink: #0b1f3a;
    --ink-2: #334a6b;
    --ink-3: #6b7e96;
    --accent: #1e4694;
    --accent-soft: #eef3fb;
    --line: #d6dde8;
    --rule: #0b1f3a;
  }
  body {
    font-family: 'Inter', sans-serif;
    font-size: 9.5px;
    line-height: 1.45;
    color: var(--ink);
    background: #fff;
    width: 302px;
    min-height: auto;
    padding: 16px;
    min-height: 1123px;
    padding: 0;
  }
  .mono { font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
  p, h1, h2, h3, h4 { margin: 0; }

  .band { background: var(--accent); color: #fff; padding: 22px 36px 24px; display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: center; }
  .band .logo-block { display: flex; align-items: center; gap: 14px; }
  .band .logo { width: 52px; height: 52px; background: rgba(255,255,255,.14); border-radius: 10px; display: flex; align-items: center; justify-content: center; }
  .band .logo svg { width: 32px; height: 32px; }
  .band .co-name { font-size: 16px; font-weight: 700; letter-spacing: 0.01em; }
  .band .co-sub { font-size: 9.5px; opacity: 0.8; margin-top: 2px; }
  .band .docbox { background: #fff; color: var(--ink); border-radius: 10px; padding: 14px 18px; min-width: 250px; text-align: right; box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .band .docbox .ruc { font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.14em; }
  .band .docbox .ruc b { color: var(--ink); }
  .band .docbox .kind { font-size: 13px; font-weight: 700; color: var(--accent); margin-top: 4px; letter-spacing: 0.04em; }
  .band .docbox .num { font-family: 'IBM Plex Mono', monospace; font-size: 22px; font-weight: 600; margin-top: 2px; }

  .sub-band { padding: 10px 36px; background: #f4f7fc; border-bottom: 1px solid var(--line); display: grid; grid-template-columns: repeat(4, 1fr); font-size: 10px; gap: 16px; }
  .sub-band .k { display: block; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; font-size: 9px; margin-bottom: 2px; }
  .sub-band .v { font-weight: 600; }

  .body-wrap { padding: 22px 36px 28px; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 18px; }
  .party { border: 1px solid var(--line); border-radius: 8px; padding: 14px 16px; }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 600; margin-bottom: 6px; }
  .party .name { font-size: 12.5px; font-weight: 600; margin-bottom: 6px; }
  .party .row { display: grid; grid-template-columns: 80px 1fr; font-size: 10px; padding: 1px 0; }
  .party .row .k { color: var(--ink-3); }

  .items { width: 100%; border-collapse: separate; border-spacing: 0; margin: 0; border-radius: 8px; overflow: hidden; border: 1px solid var(--line); }
  .items thead th { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.08em; color: #fff; font-weight: 600; background: var(--ink); text-align: left; padding: 10px 10px; }
  .items tbody td { padding: 10px; border-top: 1px solid var(--line); vertical-align: top; font-size: 9.5px; }
  .items tbody tr:first-child td { border-top: 0; }
  .items tbody tr:nth-child(even) td { background: #f8fafd; }
  .items .c-idx { width: 28px; color: var(--ink-3); text-align: center; }
  .items .c-code { width: 90px; }
  .items .c-qty, .items .c-price, .items .c-tax { text-align: right; }
  .items .c-qty { width: 60px; }
  .items .c-unit { width: 50px; text-align: center; color: var(--ink-3); }
  .items .c-price { width: 84px; }
  .items .c-tax { width: 88px; }
  .items .desc .main { font-weight: 500; }
  .items .desc .sub { font-size: 9.5px; color: var(--ink-3); margin-top: 2px; }

  .bottom { display: grid; grid-template-columns: 1fr 310px; gap: 20px; margin-top: 18px; }
  .notes .block { border: 1px solid var(--line); border-radius: 8px; padding: 10px 12px; margin-bottom: 10px; }
  .notes .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 600; margin-bottom: 4px; }
  .notes .block .body { font-size: 10px; }
  .notes .block .body p + p { margin-top: 2px; }
  .notes .small { font-size: 9.5px; color: var(--ink-2); }

  .totals { background: #f4f7fc; border: 1px solid var(--line); border-radius: 8px; padding: 14px 16px; }
  .totals .line { display: flex; justify-content: space-between; padding: 3px 0; font-size: 9.5px; }
  .totals .line .k { color: var(--ink-2); }
  .totals .line .v { font-family: 'IBM Plex Mono', monospace; white-space: nowrap; }
  .totals .rule { border-top: 1px solid var(--line); margin: 4px 0; }
  .totals .grand { display: flex; justify-content: space-between; padding: 10px 12px; margin: 8px -16px -14px; background: var(--ink); color: #fff; border-radius: 0 0 7px 7px; font-size: 15px; font-weight: 700; }
  .totals .grand .v { font-family: 'IBM Plex Mono', monospace; white-space: nowrap; }
  .totals .in-words { margin-top: 10px; font-size: 9.5px; color: var(--ink-2); font-style: italic; }

  .foot { display: grid; grid-template-columns: 100px 1fr auto; gap: 18px; align-items: start; margin-top: 20px; padding-top: 14px; border-top: 2px solid var(--ink); }
  .foot .qr { width: 100px; height: 100px; background: #fff; padding: 4px; border: 1px solid var(--line); border-radius: 6px; }
  .foot .qr svg { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: var(--ink-2); }
  .foot .meta strong { color: var(--ink); }
  .foot .meta .hash { font-family: 'IBM Plex Mono', monospace; word-break: break-all; font-size: 8.5px; margin-top: 2px; }
  .foot .stamp { text-align: right; min-width: 180px; }
  .foot .stamp .badge { display: inline-block; background: var(--accent-soft); color: var(--accent); padding: 5px 12px; border-radius: 999px; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; }
  .foot .stamp .line { font-size: 9.5px; color: var(--ink-2); margin-top: 8px; max-width: 180px; }
</style>
</head>
<body>

<div class="band">
  <div class="logo-block">
    <div class="logo">
      <svg viewBox="0 0 40 40" fill="none" stroke="#fff" stroke-width="2.4">
        <rect x="6" y="6" width="28" height="28" rx="3"/>
        <path d="M12 20h16M12 14h10M12 26h14"/>
      </svg>
    </div>
    <div>
      <div class="co-name">{{ doc.company.razonSocial }}</div>
      <div class="co-sub">{{ doc.company.address.direccion }} — Lima, Perú · ventas@andinatextil.pe · (01) 555-0102</div>
    </div>
  </div>
  <div class="docbox">
    <div class="ruc">R.U.C. <b class="mono">{{ doc.company.ruc }}</b></div>
    <div class="kind">FACTURA ELECTRÓNICA</div>
    <div class="num">{{ doc.serie }}-{{ doc.correlativo }}</div>
  </div>
</div>

<div class="sub-band">
  <div><span class="k">Fecha de emisión</span><span class="v">{{ doc.fechaEmision|date('d/m/Y') }} · 14:32</span></div>
  <div><span class="k">Vencimiento</span><span class="v">24/05/2026</span></div>
  <div><span class="k">Moneda</span><span class="v">Soles ({{ moneda }}) · T/C 3.742</span></div>
  <div><span class="k">Condición</span><span class="v">Crédito · 2 cuotas</span></div>
</div>

<div class="body-wrap">

<div class="parties">
  <div class="party">
    <div class="label">Cliente / Adquirente</div>
    <div class="name">{{ cl.rznSocial }}</div>
    <div class="row"><span class="k">RUC</span><span class="mono">{{ cl.numDoc }}</span></div>
    <div class="row"><span class="k">Dirección</span><span>{{ cl.address.direccion }}</span></div>
    <div class="row"><span class="k">Ubicación</span><span>Lima — Lima — Miraflores</span></div>
    <div class="row"><span class="k">Orden compra</span><span class="mono">OC-2026-00487</span></div>
  </div>
  <div class="party">
    <div class="label">Datos de la operación</div>
    <div class="name">0101 — Venta interna</div>
    <div class="row"><span class="k">Entrega</span><span>Almacén Los Portales · Av. Argentina 5520 — Callao</span></div>
    <div class="row"><span class="k">Guía ref.</span><span class="mono">GRE T001-00452</span></div>
    <div class="row"><span class="k">Vendedor</span><span>Diego Paredes · Ruta Lima–Callao</span></div>
  </div>
</div>

<table class="items">
  <thead>
    <tr>
      <th class="c-idx">#</th>
      <th class="c-code">Código</th>
      <th>Descripción</th>
      <th class="c-unit">Und</th>
      <th class="c-qty">Cant.</th>
      <th class="c-price">P. Unit.</th>
      <th class="c-tax">Importe</th>
    </tr>
  </thead>
  <tbody>

    {% for det in doc.details %}
    <tr>
      <td class="c-idx mono">{{ loop.index|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codProducto }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div><div class="sub">{% if det.codProductoSUNAT %}SUNAT {{ det.codProductoSUNAT }}{% endif %}</div></td>
      <td class="c-unit">{{ det.unidad }}</td>
      <td class="c-qty mono">{{ det.cantidad|n_format }}</td>
      <td class="c-price mono">{{ det.mtoValorUnitario|n_format }}</td>
      <td class="c-tax mono">{{ det.mtoValorVenta|n_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<div class="bottom">
  <div class="notes">
    <div class="block">
      <div class="head">Cuotas de pago</div>
      <div class="body">
        <p class="small">Cuota 1 · vence 24/05/2026 · <b>{{ moneda }} 5,946.20</b></p>
        <p class="small">Cuota 2 · vence 24/06/2026 · <b>{{ moneda }} 5,946.20</b></p>
      </div>
    </div>
    <div class="block">
      <div class="head">Detracción SPOT</div>
      <div class="body">
        <p><b>{{ moneda }} 1,427.09</b> · 020 Bienes gravados con IGV</p>
        <p class="small">Transferencia en cuenta · Cta. BN 00-032-019287</p>
      </div>
    </div>
    <div class="block">
      <div class="head">Observaciones</div>
      <div class="body">
        <p>Pedido fraccionado — entrega en 2 camiones.</p>
      </div>
    </div>
    <div class="block">
      <div class="head">Leyendas SUNAT</div>
      <div class="body">
        <p class="small">· SON ONCE MIL OCHOCIENTOS NOVENTA Y DOS CON 40/100 {{ moneda }}</p>
        <p class="small">· Operación sujeta a detracción</p>
      </div>
    </div>
  </div>

  <div class="totals">
    <div class="line"><span class="k">Op. gravadas</span><span class="v">{{ moneda }} {{ doc.mtoOperGravadas|n_format }}</span></div>
    <div class="line"><span class="k">Op. exoneradas</span><span class="v">{{ moneda }} 0.00</span></div>
    <div class="line"><span class="k">Op. inafectas</span><span class="v">{{ moneda }} 0.00</span></div>
    <div class="line"><span class="k">Op. gratuitas</span><span class="v">{{ moneda }} 0.00</span></div>
    <div class="rule"></div>
    <div class="line"><span class="k">IGV (18.00%)</span><span class="v">{{ moneda }} {{ doc.mtoIGV|n_format }}</span></div>
    <div class="line"><span class="k">ICBPER</span><span class="v">{{ moneda }} 0.00</span></div>
    <div class="line"><span class="k">ISC</span><span class="v">{{ moneda }} 0.00</span></div>
    <div class="in-words">Son: Once mil ochocientos noventa y dos con 40/100 soles.</div>
    <div class="grand"><span>TOTAL</span><span class="v">{{ moneda }} {{ doc.mtoImpVenta|n_format }}</span></div>
  </div>
</div>

<div class="foot">
  <div class="qr">
    <svg viewBox="0 0 21 21" shape-rendering="crispEdges"><rect width="21" height="21" fill="#fff"/>
    <g fill="#0b1f3a">
      <rect x="0" y="0" width="7" height="7"/><rect x="1" y="1" width="5" height="5" fill="#fff"/><rect x="2" y="2" width="3" height="3"/>
      <rect x="14" y="0" width="7" height="7"/><rect x="15" y="1" width="5" height="5" fill="#fff"/><rect x="16" y="2" width="3" height="3"/>
      <rect x="0" y="14" width="7" height="7"/><rect x="1" y="15" width="5" height="5" fill="#fff"/><rect x="2" y="16" width="3" height="3"/>
      <rect x="8" y="0" width="1" height="1"/><rect x="10" y="0" width="2" height="1"/><rect x="8" y="2" width="2" height="1"/><rect x="12" y="2" width="1" height="2"/>
      <rect x="5" y="8" width="2" height="2"/><rect x="8" y="8" width="2" height="1"/><rect x="11" y="8" width="1" height="2"/><rect x="13" y="8" width="3" height="1"/><rect x="17" y="8" width="1" height="2"/><rect x="19" y="8" width="2" height="1"/>
      <rect x="1" y="10" width="2" height="1"/><rect x="4" y="10" width="1" height="2"/><rect x="6" y="10" width="2" height="1"/><rect x="9" y="10" width="1" height="2"/><rect x="12" y="10" width="2" height="1"/><rect x="15" y="10" width="1" height="2"/><rect x="18" y="10" width="2" height="1"/>
      <rect x="0" y="12" width="1" height="2"/><rect x="3" y="12" width="2" height="1"/><rect x="6" y="12" width="1" height="2"/><rect x="8" y="12" width="2" height="1"/><rect x="11" y="12" width="2" height="2"/><rect x="17" y="12" width="2" height="2"/>
      <rect x="8" y="14" width="1" height="1"/><rect x="10" y="14" width="2" height="1"/><rect x="13" y="14" width="1" height="2"/><rect x="15" y="14" width="2" height="1"/><rect x="18" y="14" width="1" height="2"/>
      <rect x="8" y="16" width="2" height="1"/><rect x="11" y="16" width="1" height="2"/><rect x="14" y="16" width="2" height="1"/><rect x="17" y="16" width="1" height="1"/>
      <rect x="9" y="18" width="1" height="2"/><rect x="12" y="18" width="2" height="1"/><rect x="15" y="18" width="1" height="2"/><rect x="17" y="18" width="2" height="1"/>
      <rect x="8" y="20" width="1" height="1"/><rect x="11" y="20" width="3" height="1"/><rect x="15" y="20" width="1" height="1"/><rect x="18" y="20" width="1" height="1"/>
    </g></svg>
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la Factura Electrónica.</p>
    <p>Consulte la validez en <strong>sunat.gob.pe</strong> con el RUC del emisor y el número del documento.</p>
    <p style="margin-top:6px;">Firmante digital: {{ doc.company.ruc }} · Manufacturas Andina Textil S.A.C.</p>
    <p class="hash">Hash: 3f8a21bc9d7e04a6c2f1b8e0d4a7c9f2e5b6d8a1</p>
  </div>
  <div class="stamp">
    <span class="badge">● CPE autorizado SUNAT</span>
    <div class="line">Documento electrónico emitido conforme al Reglamento de Comprobantes de Pago.</div>
  </div>
</div>

</div>
</body>
</html>
