<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.remitente %}
{% set tercero = doc.tercero %}
{% set cl = doc.destinatario %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root { --ink: #0f0f10; --ink-2: #4a4a50; --ink-3: #8c8c94; --accent: #ff5a1f; --accent-soft: #fff1ea; --line: #e8e6df; --paper: #fbfaf4; }
  body { font-family: 'Archivo', sans-serif; font-size: 10.5px; line-height: 1.45; color: var(--ink); background: var(--paper); width: 794px; min-height: 1123px; padding: 36px 40px; }
  .mono { font-family: 'JetBrains Mono', monospace; font-variant-numeric: tabular-nums; }
  p { margin: 0; }

  .hero { display: grid; grid-template-columns: 1fr 290px; gap: 24px; align-items: stretch; margin-bottom: 16px; }
  .hero .left { padding: 22px 24px; border: 1.5px solid var(--ink); border-radius: 4px; background: #fff; }
  .hero .left .mark { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .hero .left .logo { width: 44px; height: 44px; background: var(--ink); color: var(--accent); border-radius: 2px; display: flex; align-items: center; justify-content: center; }
  .hero .left .logo svg { width: 26px; height: 26px; }
  .hero .left .logo img { width: 100%; height: 100%; object-fit: contain; border-radius: 2px; }
  .hero .left .co-name { font-size: 17px; font-weight: 900; letter-spacing: -0.01em; line-height: 1.1; }
  .hero .left .co-tag { font-size: 10px; color: var(--ink-2); margin-top: 2px; font-weight: 500; }
  .hero .left .info { font-size: 10px; color: var(--ink-2); }
  .hero .left .info p { padding: 1px 0; }
  .hero .left .info b { color: var(--ink); font-family: 'JetBrains Mono', monospace; }

  .hero .right { padding: 20px 22px; background: var(--ink); color: #fff; border-radius: 4px; display: flex; flex-direction: column; justify-content: space-between; }
  .hero .right .kind { font-size: 12px; font-weight: 700; color: var(--accent); letter-spacing: 0.04em; text-transform: uppercase; }
  .hero .right .subkind { font-size: 10px; opacity: 0.7; margin-top: 1px; }
  .hero .right .num { font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 700; margin-top: 4px; letter-spacing: 0.02em; }
  .hero .right .rule { height: 1px; background: rgba(255,255,255,0.18); margin: 12px 0; }
  .hero .right .row { display: flex; justify-content: space-between; font-size: 10px; padding: 1.5px 0; }
  .hero .right .row .k { opacity: 0.62; }
  .hero .right .row .v { font-weight: 500; }

  .route { background: var(--accent); color: var(--ink); border-radius: 4px; padding: 14px 18px; display: grid; grid-template-columns: 1fr auto 1fr; gap: 16px; align-items: center; margin-bottom: 14px; }
  .route .leg .k { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; font-weight: 800; }
  .route .leg .v { font-size: 12.5px; font-weight: 800; margin-top: 2px; }
  .route .leg .a { font-size: 9.5px; font-weight: 500; margin-top: 1px; }
  .route .arrow { font-size: 22px; font-weight: 900; }
  .route .leg.right { text-align: right; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 14px; }
  .party { background: #fff; border-radius: 4px; border: 1px solid var(--line); padding: 14px 16px; position: relative; }
  .party::before { content: ""; position: absolute; left: 0; top: 14px; bottom: 14px; width: 3px; background: var(--accent); border-radius: 0 2px 2px 0; }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--accent); font-weight: 700; margin-bottom: 4px; }
  .party .name { font-size: 13px; font-weight: 700; margin-bottom: 5px; letter-spacing: -0.005em; }
  .party .row { display: grid; grid-template-columns: 72px 1fr; font-size: 10px; padding: 1px 0; }
  .party .row .k { color: var(--ink-3); }

  .strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 14px; }
  .strip .chip { background: #fff; border: 1px solid var(--line); border-radius: 4px; padding: 9px 12px; }
  .strip .chip .k { font-size: 8.5px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 700; display: block; margin-bottom: 2px; }
  .strip .chip .v { font-size: 11px; font-weight: 600; }

  .items-wrap { background: #fff; border-radius: 4px; border: 1px solid var(--line); overflow: hidden; }
  .items { width: 100%; border-collapse: collapse; }
  .items thead th { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; font-weight: 700; text-align: left; padding: 12px; background: var(--ink); }
  .items tbody td { padding: 10px 12px; border-top: 1px solid var(--line); vertical-align: top; font-size: 10.5px; }
  .items .c-idx { width: 34px; text-align: center; color: var(--accent); font-weight: 700; }
  .items .c-code { width: 90px; }
  .items .c-qty { text-align: right; width: 80px; font-weight: 600; }
  .items .c-unit { width: 50px; text-align: center; color: var(--ink-3); }
  .items .desc .main { font-weight: 600; }
  .items .desc .sub { font-size: 9.5px; color: var(--ink-3); margin-top: 2px; font-weight: 400; }

  .transport { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 14px; }
  .transport .card { background: var(--ink); color: #fff; border-radius: 4px; padding: 14px 16px; }
  .transport .card .head { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .transport .card .head .icon { color: var(--accent); }
  .transport .card .head .title { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); }
  .transport .card .row { display: grid; grid-template-columns: 84px 1fr; font-size: 10px; padding: 1.5px 0; }
  .transport .card .row .k { opacity: 0.6; }
  .transport .card .row .v { font-weight: 500; }

  .related { background: #fff; border: 1px solid var(--line); border-radius: 4px; padding: 12px 16px; margin-top: 14px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .related .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 700; margin-bottom: 4px; }
  .related .block .body { font-size: 10px; }
  .related .small { font-size: 9.5px; color: var(--ink-2); }

  .foot { display: grid; grid-template-columns: 96px 1fr auto; gap: 18px; align-items: start; margin-top: 16px; padding-top: 14px; border-top: 2px solid var(--ink); }
  .foot .qr { width: 96px; height: 96px; background: #fff; padding: 4px; border-radius: 4px; border: 1.5px solid var(--ink); }
  .foot .qr img { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: var(--ink-2); }
  .foot .meta strong { color: var(--ink); }
  .foot .meta .hash { font-family: 'JetBrains Mono', monospace; word-break: break-all; font-size: 8.5px; margin-top: 4px; color: var(--ink-3); }
  .foot .stamp { text-align: right; min-width: 180px; }
  .foot .stamp .badge { display: inline-block; background: var(--ink); color: var(--accent); padding: 6px 12px; border-radius: 2px; font-size: 9.5px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; }
  .foot .stamp .line { font-size: 9.5px; color: var(--ink-2); margin-top: 8px; max-width: 190px; }
</style>
</head>
<body>

<div class="hero">
  <div class="left">
    <div class="mark">
      <div class="logo">{% if params.logo is not empty %}<img src="{{ params.logo }}" alt="logo"/>{% else %}<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="3"><circle cx="20" cy="20" r="14"/><path d="M9 23l5-9 6 4 6-7"/></svg>{% endif %}</div>
      <div>
        <div class="co-name">{% if cp is not null %}{{ cp.razonSocial }}{% endif %}</div>
        <div class="co-tag">{% if cp is not null and cp.nombreComercial is not empty %}{{ cp.nombreComercial }}{% endif %}{% if params.establishmentName is not empty %}{% if cp is not null and cp.nombreComercial is not empty %} · {% endif %}{{ params.establishmentName }}{% endif %}</div>
      </div>
    </div>
    <div class="info">
      {% if cp is not null and cp.direccion is not null %}<p>{{ cp.direccion.direccion }}{% if cp.direccion.distrito is not empty %} · {{ cp.direccion.departamento }} — {{ cp.direccion.provincia }} — {{ cp.direccion.distrito }}{% endif %}{% if cp.direccion.ubigeo is not empty %} · Ubigeo {{ cp.direccion.ubigeo }}{% endif %}</p>{% if cp.contacto is not null and (cp.contacto.email is not empty or cp.contacto.telefono is not empty) %}<p>{% if cp.contacto.email is not empty %}{{ cp.contacto.email }}{% endif %}{% if cp.contacto.telefono is not empty %} · {{ cp.contacto.telefono }}{% endif %}</p>{% endif %}{% endif %}
      {% if cp is not null and cp.contacto is not null %}<p>{{ cp.contacto.email }} · {{ cp.contacto.telefono }}</p>{% endif %}
      <p>RUC <b>{% if cp is not null %}{{ cp.ruc }}{% endif %}</b>{% if doc.envio is not null and doc.envio.transportista is not null and doc.envio.transportista.numeroRegistroMTC is not empty %} · Reg. MTC <b>{{ doc.envio.transportista.numeroRegistroMTC }}</b>{% endif %}</p>
      {% if params.subcontratistaNombre is not empty %}<p>Subcontratista: <b>{{ params.subcontratistaNombre }}</b>{% if params.subcontratistaRuc is not empty %} · RUC {{ params.subcontratistaRuc }}{% endif %}{% if params.subcontratistaMtc is not empty %} · MTC {{ params.subcontratistaMtc }}{% endif %}</p>{% endif %}
      {% if doc.subcontratado is not null %}<p>Subcontratado por: <b>{{ doc.subcontratado.nombre }}</b>{% if doc.subcontratado.numeroDocumentoIdentidad is not empty %} · {{ doc.subcontratado.numeroDocumentoIdentidad }}{% endif %}</p>{% endif %}
    </div>
  </div>
  <div class="right">
    <div>
      <div class="kind">{{ name|upper }} ELECTRÓNICA</div>
      <div class="num">{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }}</div>
    </div>
    <div>
      <div class="rule"></div>
      <div class="row"><span class="k">Emitido</span><span class="v">{{ doc.fechaEmision|date('d/m/Y') }}{% if doc.horaEmision is not null %} · {{ doc.horaEmision }}{% endif %}</span></div>
      <div class="row"><span class="k">Inicio traslado</span><span class="v">{% if doc.envio is not null and doc.envio.fechaTraslado is not null %}{{ doc.envio.fechaTraslado|date('d/m/Y') }}{% endif %}</span></div>
      <div class="row"><span class="k">Modalidad</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.tipoModalidadTraslado|catalog('18') }}{% endif %}</span></div>
      <div class="row"><span class="k">Peso · bultos</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.pesoTotal }} {{ doc.envio.pesoTotalUnidadMedida }}{% if doc.envio.numeroDeBultos is not null %} · {{ doc.envio.numeroDeBultos }}{% endif %}{% endif %}</span></div>
      {% if params.estadoPago is not empty %}<div class="row"><span class="k">Estado de pago</span><span class="v">{{ params.estadoPago }}</span></div>{% endif %}
      {% if params.trackingNumber is not empty %}<div class="row"><span class="k">Nro. taquito</span><span class="v mono">{{ params.trackingNumber }}</span></div>{% endif %}
    </div>
  </div>
</div>

<div class="route">
  <div class="leg">
    <div class="k">Partida</div>
    <div class="v">{% if doc.envio is not null and doc.envio.partida is not null %}{{ doc.envio.partida.direccion }}{% endif %}</div>
    <div class="a">{% if doc.envio is not null and doc.envio.partida is not null %}Ubigeo {{ doc.envio.partida.ubigeo }}{% endif %}</div>
  </div>
  <div class="arrow">→</div>
  <div class="leg right">
    <div class="k">Llegada</div>
    <div class="v">{% if doc.envio is not null and doc.envio.destino is not null %}{{ doc.envio.destino.direccion }}{% endif %}</div>
    <div class="a">{% if doc.envio is not null and doc.envio.destino is not null %}Ubigeo {{ doc.envio.destino.ubigeo }}{% endif %}</div>
  </div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Remitente</div>
    {% if tercero is not null %}
    <div class="name">{{ tercero.nombre }}</div>
    <div class="row"><span class="k">{{ tercero.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ tercero.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
    {% if doc.envio is not null and doc.envio.partida is not null %}
    <div class="row"><span class="k">Dirección</span><span>{{ doc.envio.partida.direccion }}</span></div>
    <div class="row"><span class="k">Distrito</span><span>{% if params.partidaDistrito is not empty %}{{ params.partidaDistrito }} - {% endif %}{{ doc.envio.partida.ubigeo }}</span></div>
    {% endif %}
  </div>
  <div class="party">
    <div class="label">Destinatario</div>
    {% if cl is not null %}
    <div class="name">{{ cl.nombre }}</div>
    <div class="row"><span class="k">{{ cl.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ cl.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
    {% if doc.envio is not null and doc.envio.destino is not null %}
    <div class="row"><span class="k">Dirección</span><span>{{ doc.envio.destino.direccion }}</span></div>
    <div class="row"><span class="k">Distrito</span><span>{% if params.destinoDistrito is not empty %}{{ params.destinoDistrito }} - {% endif %}{{ doc.envio.destino.ubigeo }}</span></div>
    {% endif %}
  </div>
</div>

<div class="items-wrap">
<table class="items">
  <thead>
    <tr><th class="c-idx">#</th><th class="c-code">Código</th><th>Descripción del bien</th><th class="c-unit">Und</th><th class="c-qty">Cant.</th></tr>
  </thead>
  <tbody>
    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codigo }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div></td>
      <td class="c-unit">{{ det.unidadMedida }}</td>
      <td class="c-qty mono">{{ det.cantidad|n_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
  {% if params.totalGuia is not empty and params.totalGuia > 0 %}<tfoot><tr><td colspan="99" style="text-align:right;padding:10px 12px;font-weight:700;">Monto total: S/ {{ params.totalGuia|n_format }}</td></tr></tfoot>{% endif %}
</table>
</div>

<div class="transport">
  <div class="card">
    <div class="head"><div class="icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 17V7h13l5 5v5M3 17h2M9 17h10M5 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm14 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></svg></div><div class="title">Vehículos</div></div>
    {% if doc.envio is not null and doc.envio.vehiculo is not null %}
    <div class="row"><span class="k">Placa principal</span><span class="v mono">{{ doc.envio.vehiculo.placa }}</span></div>
    {% if doc.envio.vehiculo.numeroCirculacion is not empty %}<div class="row"><span class="k">TUC/CHV</span><span class="v mono">{{ doc.envio.vehiculo.numeroCirculacion }}</span></div>{% endif %}
    {% if doc.envio.vehiculo.numeroAutorizacion is not empty %}<div class="row"><span class="k">Autorización</span><span class="v mono">{{ doc.envio.vehiculo.numeroAutorizacion }}</span></div>{% endif %}
    {% if doc.envio.vehiculo.secundarios is not empty %}{% for v in doc.envio.vehiculo.secundarios %}
    <div class="row"><span class="k">Placa secundaria</span><span class="v mono">{{ v.placa }}{% if v.numeroCirculacion is not empty %} · TUC {{ v.numeroCirculacion }}{% endif %}</span></div>
    {% endfor %}{% endif %}
    {% endif %}
  </div>
  <div class="card">
    <div class="head"><div class="icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg></div><div class="title">Conductores</div></div>
    {% if doc.envio is not null and doc.envio.choferes is not empty %}{% for ch in doc.envio.choferes %}
    <div class="row"><span class="k">{% if loop.first %}Conductor principal{% else %}Conductor secundario{% endif %}</span><span class="v">{{ ch.nombres }} {{ ch.apellidos }}</span></div>
    <div class="row"><span class="k">{{ ch.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }} · Brevete</span><span class="v mono">{{ ch.numeroDocumentoIdentidad }}{% if ch.licencia is not empty %} · {{ ch.licencia }}{% endif %}</span></div>
    {% endfor %}{% endif %}
  </div>
</div>

{% if doc.documentosRelacionados is not empty or doc.observaciones is not empty %}
<div class="related">
  <div class="block">
    <div class="head">Documentos relacionados</div>
    <div class="body">
      {% for rel in doc.documentosRelacionados %}
      <p>{{ rel.tipoDocumento }} · <span class="mono">{{ rel.serieNumero }}</span></p>
      {% endfor %}
    </div>
  </div>
  <div class="block">
    <div class="head">Observaciones</div>
    <div class="body">
      {% if doc.observaciones is not empty %}{% for obs in doc.observaciones|split('\n') %}<p class="small">· {{ obs }}</p>{% endfor %}{% endif %}
    </div>
  </div>
</div>
{% endif %}

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}<img src="data:image/png;base64,{{ qrBase64 }}" alt="QR Code" />{% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la Guía de Remisión Transportista Electrónica.</p>
    <p>Consulte la validez en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> con el RUC del transportista y el número del documento.</p>
    <p style="margin-top:6px;">Firmante: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    {% if hashDocumento is not empty %}<p class="hash">Hash: {{ hashDocumento }}</p>{% endif %}
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">● GRE-T SUNAT</span>
    <div class="line">Documento electrónico emitido conforme a la RS SUNAT 271-2019.</div>
  </div>
</div>

</body>
</html>
