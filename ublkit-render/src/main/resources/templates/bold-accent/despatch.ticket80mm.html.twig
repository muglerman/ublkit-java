<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
{% set cp = doc.remitente %}
{% set cl = doc.destinatario %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root {
    --ink: #0f0f10;
    --ink-2: #4a4a50;
    --ink-3: #8c8c94;
    --accent: #ff5a1f;
    --accent-soft: #fff1ea;
    --line: #e8e6df;
    --paper: #fbfaf4;
  }
  body {
    font-family: 'Archivo', sans-serif;
    font-size: 9px;
    line-height: 1.45;
    color: var(--ink);
    background: var(--paper);
    width: 302px;
    min-height: auto;
    padding: 12px;
  }
  .mono { font-family: 'JetBrains Mono', monospace; font-variant-numeric: tabular-nums; }
  p { margin: 0; }

  .hero { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
  .hero .left { padding: 12px; border: 1.5px solid var(--ink); border-radius: 4px; background: #fff; }
  .hero .left .mark { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .hero .left .logo { width: 32px; height: 32px; background: var(--ink); color: var(--accent); border-radius: 2px; display: flex; align-items: center; justify-content: center; }
  .hero .left .logo svg { width: 20px; height: 20px; }
  .hero .left .co-name { font-size: 14px; font-weight: 900; letter-spacing: -0.01em; line-height: 1.1; }
  .hero .left .info { font-size: 9px; color: var(--ink-2); }
  
  .hero .right { padding: 12px; background: var(--ink); color: #fff; border-radius: 4px; }
  .hero .right .kind { font-size: 11px; font-weight: 700; color: var(--accent); text-transform: uppercase; }
  .hero .right .num { font-family: 'JetBrains Mono', monospace; font-size: 18px; font-weight: 700; margin-top: 2px; }
  .hero .right .rule { height: 1px; background: rgba(255,255,255,0.18); margin: 8px 0; }
  .hero .right .row { display: flex; justify-content: space-between; font-size: 9px; padding: 1px 0; }
  .hero .right .row .k { opacity: 0.62; }

  .parties { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }
  .party { background: #fff; border-radius: 4px; border: 1px solid var(--line); padding: 10px; position: relative; }
  .party::before { content: ""; position: absolute; left: 0; top: 10px; bottom: 10px; width: 3px; background: var(--accent); border-radius: 0 2px 2px 0; }
  .party .label { font-size: 8px; text-transform: uppercase; color: var(--accent); font-weight: 700; margin-bottom: 3px; }
  .party .name { font-size: 11px; font-weight: 700; margin-bottom: 4px; }
  .party .row { display: grid; grid-template-columns: 60px 1fr; font-size: 9px; padding: 1px 0; }
  .party .row .k { color: var(--ink-3); }

  .items-wrap { background: #fff; border-radius: 4px; border: 1px solid var(--line); overflow: hidden; }
  .items { width: 100%; border-collapse: collapse; }
  .items thead th { font-size: 8.5px; text-transform: uppercase; color: #fff; font-weight: 700; text-align: left; padding: 8px; background: var(--ink); }
  .items tbody td { padding: 8px; border-top: 1px solid var(--line); vertical-align: top; font-size: 9px; }
  .items .c-qty { text-align: right; width: 50px; font-weight: 600; }
  .items .desc .main { font-weight: 600; }
  .items .desc .sub { font-size: 8px; color: var(--ink-3); margin-top: 2px; }

  .foot { margin-top: 16px; text-align: center; border-top: 1px solid var(--ink); padding-top: 12px; }
  .foot .qr { margin: 0 auto 12px; width: 100px; height: 100px; background: #fff; padding: 4px; border: 1px solid var(--line); }
  .foot .qr img { width: 100%; height: 100%; }
  .foot .meta { font-size: 9px; color: var(--ink-2); }
  .foot .hash { font-family: 'JetBrains Mono', monospace; font-size: 8px; margin-top: 4px; color: var(--ink-3); word-break: break-all; }
</style>
</head>
<body>

<div class="hero">
  <div class="left">
    <div class="mark">
      <div class="logo">
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="3">
          <rect x="6" y="6" width="28" height="28" rx="2"/>
          <path d="M12 20h16M12 14h10M12 26h14"/>
        </svg>
      </div>
      <div>
        <div class="co-name">{{ cp.razonSocial }}</div>
      </div>
    </div>
    <div class="info">
      <p>{{ cp.direccion.direccion }}</p>
      <p>RUC <b>{{ cp.ruc }}</b></p>
    </div>
  </div>
  <div class="right">
    <div class="kind">{{ name }}</div>
    <div class="num">{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }}</div>
    <div class="rule"></div>
    <div class="row"><span class="k">F. Emisión</span><span class="v">{{ doc.fechaEmision|date('d/m/Y') }}</span></div>
    <div class="row"><span class="k">F. Traslado</span><span class="v">{{ doc.envio.fechaTraslado|date('d/m/Y') }}</span></div>
    <div class="row"><span class="k">Motivo</span><span class="v">{{ doc.envio.motivoTraslado|catalog('20') }}</span></div>
  </div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Destinatario</div>
    <div class="name">{{ cl.nombre }}</div>
    <div class="row"><span class="k">{{ cl.tipoDocumentoIdentidad|catalog('06') }}</span><span class="mono">{{ cl.numeroDocumentoIdentidad }}</span></div>
  </div>
  
  <div class="party">
    <div class="label">Traslado</div>
    <div class="row"><span class="k">Partida</span><span>{{ doc.envio.puntoPartida.direccion }}</span></div>
    <div class="row"><span class="k">Llegada</span><span>{{ doc.envio.puntoLlegada.direccion }}</span></div>
    {% if doc.envio.transportista %}
    <div class="row"><span class="k">Transporte</span><span>{{ doc.envio.transportista.nombre }}</span></div>
    <div class="row"><span class="k">RUC</span><span class="mono">{{ doc.envio.transportista.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
  </div>
</div>

<div class="items-wrap">
<table class="items">
  <thead>
    <tr><th>Descripción</th><th class="c-qty">Cant.</th></tr>
  </thead>
  <tbody>
    {% for det in doc.detalles %}
    <tr>
      <td class="desc">
        <div class="main">{{ det.descripcion }}</div>
        <div class="sub">{{ det.codigo }} · {{ det.unidadMedida }}</div>
      </td>
      <td class="c-qty mono">{{ det.cantidad|n_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}
      <img src="data:image/png;base64,{{ qrBase64 }}" alt="QR" />
    {% endif %}
  </div>
  <div class="meta">
    <p>Representación impresa de la {{ name }}.</p>
    <p>Firmante: {{ cp.ruc }}</p>
    <p class="hash">Hash: {{ hashDocumento }}</p>
  </div>
</div>

</body>
</html>
