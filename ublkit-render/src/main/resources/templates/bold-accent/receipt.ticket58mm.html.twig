<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
{% set cp = doc.emisor %}
{% set cl = doc.receptor %}
{% set mon = doc.moneda|catalog('02') %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root {
    --ink: #0f0f10;
    --ink-2: #4a4a50;
    --ink-3: #8c8c94;
    --accent: #ff5a1f;
    --accent-soft: #fff1ea;
    --line: #e8e6df;
    --paper: #fbfaf4;
  }
  body {
    font-family: 'Archivo', sans-serif;
    font-size: 8px;
    line-height: 1.45;
    color: var(--ink);
    background: var(--paper);
    width: 219px;
    min-height: auto;
    padding: 10px;
  }
  .mono { font-family: 'JetBrains Mono', monospace; font-variant-numeric: tabular-nums; }
  p { margin: 0; }

  .hero { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }
  .hero .left { padding: 10px; border: 1.5px solid var(--ink); border-radius: 4px; background: #fff; }
  .hero .left .mark { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .hero .left .logo { width: 28px; height: 28px; background: var(--ink); color: var(--accent); border-radius: 2px; display: flex; align-items: center; justify-content: center; }
  .hero .left .logo svg { width: 18px; height: 18px; }
  .hero .left .co-name { font-size: 12px; font-weight: 900; letter-spacing: -0.01em; line-height: 1.1; }
  .hero .left .info { font-size: 8px; color: var(--ink-2); }
  
  .hero .right { padding: 10px; background: var(--ink); color: #fff; border-radius: 4px; }
  .hero .right .kind { font-size: 10px; font-weight: 700; color: var(--accent); text-transform: uppercase; }
  .hero .right .num { font-family: 'JetBrains Mono', monospace; font-size: 15px; font-weight: 700; margin-top: 2px; }
  .hero .right .rule { height: 1px; background: rgba(255,255,255,0.18); margin: 6px 0; }
  .hero .right .row { display: flex; justify-content: space-between; font-size: 8px; padding: 1px 0; }
  .hero .right .row .k { opacity: 0.62; }

  .parties { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
  .party { background: #fff; border-radius: 4px; border: 1px solid var(--line); padding: 8px; position: relative; }
  .party::before { content: ""; position: absolute; left: 0; top: 8px; bottom: 8px; width: 3px; background: var(--accent); border-radius: 0 2px 2px 0; }
  .party .label { font-size: 7.5px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); font-weight: 700; margin-bottom: 2px; }
  .party .name { font-size: 10px; font-weight: 700; margin-bottom: 3px; }
  .party .row { display: grid; grid-template-columns: 50px 1fr; font-size: 8.5px; padding: 0.5px 0; }
  .party .row .k { color: var(--ink-3); }

  .items-wrap { background: #fff; border-radius: 4px; border: 1px solid var(--line); overflow: hidden; }
  .items { width: 100%; border-collapse: collapse; }
  .items thead th { font-size: 8px; text-transform: uppercase; color: #fff; font-weight: 700; text-align: left; padding: 6px; background: var(--ink); }
  .items tbody td { padding: 6px; border-top: 1px solid var(--line); vertical-align: top; font-size: 8.5px; }
  .items .c-qty { text-align: right; width: 40px; font-weight: 600; }
  .items .c-total { text-align: right; width: 60px; font-weight: 600; }
  .items .desc .main { font-weight: 600; }
  .items .desc .sub { font-size: 8px; color: var(--ink-3); margin-top: 2px; }

  .bottom { margin-top: 10px; }
  .notes .block { background: #fff; border: 1px solid var(--line); border-radius: 4px; padding: 6px; margin-bottom: 4px; }
  .notes .block .head { font-size: 7.5px; text-transform: uppercase; color: var(--accent); font-weight: 700; margin-bottom: 2px; }
  .notes .block .body { font-size: 8.5px; }
  .notes .small { font-size: 8px; color: var(--ink-2); }

  .totals { background: #fff; border: 1px solid var(--line); border-radius: 4px; overflow: hidden; margin-top: 6px; }
  .totals .inner { padding: 8px; }
  .totals .line { display: flex; justify-content: space-between; padding: 1.5px 0; font-size: 8.5px; }
  .totals .line .k { color: var(--ink-2); }
  .totals .rule { border-top: 1px dashed var(--line); margin: 3px 0; }
  .totals .grand-wrap { background: var(--accent); color: var(--ink); padding: 8px; }
  .totals .grand { display: flex; justify-content: space-between; align-items: baseline; }
  .totals .grand .k { font-size: 9px; font-weight: 800; }
  .totals .grand .v { font-family: 'JetBrains Mono', monospace; font-size: 14px; font-weight: 800; }

  .foot { margin-top: 12px; text-align: center; border-top: 1px solid var(--ink); padding-top: 10px; }
  .foot .qr { margin: 0 auto 10px; width: 80px; height: 80px; background: #fff; padding: 3px; border: 1px solid var(--line); }
  .foot .qr img { width: 100%; height: 100%; }
  .foot .meta { font-size: 8px; color: var(--ink-2); }
  .foot .hash { font-family: 'JetBrains Mono', monospace; font-size: 7px; margin-top: 3px; color: var(--ink-3); word-break: break-all; }
</style>
</head>
<body>

<div class="hero">
  <div class="left">
    <div class="mark">
      <div class="logo">
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="3">
          <rect x="6" y="6" width="28" height="28" rx="2"/>
          <path d="M12 20h16M12 14h10M12 26h14"/>
        </svg>
      </div>
      <div>
        <div class="co-name">{{ cp.razonSocial }}</div>
      </div>
    </div>
    <div class="info">
      <p>{{ cp.direccion.direccion }}</p>
      <p>RUC <b>{{ cp.ruc }}</b></p>
    </div>
  </div>
  <div class="right">
    <div class="kind">{{ name }}</div>
    <div class="num">{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }}</div>
    <div class="rule"></div>
    <div class="row"><span class="k">Emitido</span><span class="v">{{ doc.fechaEmision|date('d/m/Y') }}{% if doc.horaEmision is not null %} · {{ doc.horaEmision }}{% endif %}</span></div>
    <div class="row"><span class="k">Moneda</span><span class="v">{{ mon }}</span></div>
  </div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Cliente</div>
    <div class="name">{{ cl.nombre }}</div>
    <div class="row"><span class="k">{{ cl.tipoDocIdentidad|catalog('06') }}</span><span class="mono">{{ cl.numDocIdentidad }}</span></div>
  </div>
</div>

<div class="items-wrap">
<table class="items">
  <thead>
    <tr><th>Descripción</th><th class="c-qty">Cant.</th><th class="c-total">Total</th></tr>
  </thead>
  <tbody>
    {% for det in doc.detalles %}
    <tr>
      <td class="desc">
        <div class="main">{{ det.descripcion }}</div>
        <div class="sub">{{ det.codigoProducto }} · {{ det.unidadMedida }}</div>
      </td>
      <td class="c-qty mono">{{ det.cantidad|n_format }}</td>
      <td class="c-total mono">{{ det.mtoValorVenta|n_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>

<div class="bottom">
  <div class="notes">
    {% if doc.formaDePago and doc.formaDePago.cuotas %}
    <div class="block"><div class="head">Cuotas</div><div class="body">
      {% for cuota in doc.formaDePago.cuotas %}
      <p class="small">Cuota {{ loop.index }} · {{ cuota.fechaPago|date('d/m/Y') }} · <b>{{ mon }} {{ cuota.monto|n_format }}</b></p>
      {% endfor %}
    </div></div>
    {% endif %}

    {% if doc.observaciones %}
    <div class="block"><div class="head">Observaciones</div><div class="body">{{ doc.observaciones }}</div></div>
    {% endif %}

    {% if doc.leyendas is not empty %}
    <div class="block"><div class="head">Leyendas</div><div class="body">
      {% for entry in doc.leyendas %}
        <p class="small">· {{ entry.value }}</p>
      {% endfor %}
    </div></div>
    {% endif %}
  </div>

  <div class="totals">
    <div class="inner">
      {% if doc.totalImporte is defined and doc.totalImporte is not null and doc.totalImporte.importeSinImpuestos is not null %}
      <div class="line"><span class="k">Subtotal</span><span class="v">{{ mon }} {{ doc.totalImporte.importeSinImpuestos|n_format }}</span></div>
      {% endif %}
      {% if doc.totalImpuestos.gravadoBaseImponible %}
      <div class="line"><span class="k">Op. gravadas</span><span class="v">{{ mon }} {{ doc.totalImpuestos.gravadoBaseImponible|n_format }}</span></div>
      {% endif %}
      <div class="rule"></div>
      {% if doc.totalImpuestos.gravadoImporte %}
      <div class="line"><span class="k">IGV (18%)</span><span class="v">{{ mon }} {{ doc.totalImpuestos.gravadoImporte|n_format }}</span></div>
      {% endif %}
    </div>
    <div class="grand-wrap">
      <div class="grand"><span class="k">TOTAL</span><span class="v">{{ mon }} {{ doc.totalImporte.importeConImpuestos|n_format }}</span></div>
    </div>
  </div>
</div>

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}
      <img src="data:image/png;base64,{{ qrBase64 }}" alt="QR" />
    {% endif %}
  </div>
  <div class="meta">
    <p>Representación impresa de la {{ name }} Electrónica.</p>
    <p>Firmante: {{ cp.ruc }}</p>
    <p class="hash">Hash: {{ hashDocumento }}</p>
  </div>
</div>

</body>
</html>
