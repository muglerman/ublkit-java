<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
{% set cp = doc.emisor %}
<title>{{ doc.correlativo }} · Comunicación de Baja</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root {
    --ink: #0f0f10;
    --ink-2: #4a4a50;
    --ink-3: #8c8c94;
    --accent: #ff5a1f;
    --accent-soft: #fff1ea;
    --line: #e8e6df;
    --paper: #fbfaf4;
  }
  body {
    font-family: 'Archivo', sans-serif;
    font-size: 10.5px;
    line-height: 1.45;
    color: var(--ink);
    background: var(--paper);
    width: 794px;
    min-height: 1123px;
    padding: 36px 40px;
  }
  .mono { font-family: 'JetBrains Mono', monospace; font-variant-numeric: tabular-nums; }
  p { margin: 0; }

  .hero { display: grid; grid-template-columns: 1fr 290px; gap: 24px; align-items: stretch; margin-bottom: 18px; }
  .hero .left { padding: 22px 24px; border: 1.5px solid var(--ink); border-radius: 4px; background: #fff; }
  .hero .left .mark { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .hero .left .logo { width: 44px; height: 44px; background: var(--ink); color: var(--accent); border-radius: 2px; display: flex; align-items: center; justify-content: center; }
  .hero .left .logo svg { width: 26px; height: 26px; }
  .hero .left .co-name { font-size: 18px; font-weight: 900; letter-spacing: -0.01em; line-height: 1.1; }
  .hero .left .co-tag { font-size: 10px; color: var(--ink-2); margin-top: 2px; font-weight: 500; }
  .hero .left .info { font-size: 10px; color: var(--ink-2); }
  .hero .left .info p { padding: 1px 0; }
  .hero .left .info b { color: var(--ink); font-family: 'JetBrains Mono', monospace; }

  .hero .right { padding: 20px 22px; background: var(--ink); color: #fff; border-radius: 4px; display: flex; flex-direction: column; justify-content: space-between; }
  .hero .right .kind { font-size: 13px; font-weight: 700; color: var(--accent); letter-spacing: 0.04em; text-transform: uppercase; }
  .hero .right .num { font-family: 'JetBrains Mono', monospace; font-size: 26px; font-weight: 700; margin-top: 4px; letter-spacing: 0.02em; }
  .hero .right .rule { height: 1px; background: rgba(255,255,255,0.18); margin: 12px 0; }
  .hero .right .row { display: flex; justify-content: space-between; font-size: 10px; padding: 1px 0; }
  .hero .right .row .k { opacity: 0.62; }

  .items-wrap { background: #fff; border-radius: 4px; border: 1px solid var(--line); overflow: hidden; margin-top: 20px; }
  .items { width: 100%; border-collapse: collapse; }
  .items thead th { font-size: 9px; text-transform: uppercase; color: #fff; font-weight: 700; text-align: left; padding: 12px; background: var(--ink); }
  .items tbody td { padding: 12px; border-top: 1px solid var(--line); vertical-align: top; font-size: 10px; }
  .items .c-idx { width: 40px; text-align: center; color: var(--accent); font-weight: 700; }
  .items .c-doc { width: 150px; font-family: 'JetBrains Mono', monospace; }

  .foot { display: grid; grid-template-columns: 100px 1fr auto; gap: 20px; align-items: start; margin-top: 24px; padding-top: 16px; border-top: 2px solid var(--ink); }
  .foot .qr { width: 100px; height: 100px; background: #fff; padding: 4px; border-radius: 4px; border: 1px solid var(--line); }
  .foot .qr img { width: 100%; height: 100%; }
  .foot .meta { font-size: 10px; color: var(--ink-2); }
  .foot .meta strong { color: var(--ink); }
  .foot .meta .hash { font-family: 'JetBrains Mono', monospace; font-size: 9px; margin-top: 4px; color: var(--ink-3); word-break: break-all; }
  .foot .stamp { text-align: right; }
  .foot .stamp .badge { display: inline-block; background: var(--ink); color: var(--accent); padding: 6px 12px; border-radius: 2px; font-size: 10px; font-weight: 800; text-transform: uppercase; }
</style>
</head>
<body>
{% if params.header is not null %}
<div id="custom-header-box" style="background: var(--accent-soft); padding: 10px; border-radius: 4px; margin-bottom: 10px; border: 1px solid var(--accent);">
  {{ params.header }}
</div>
{% endif %}

<div class="hero">
  <div class="left">
    <div class="mark">
      <div class="logo">
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="3">
          <rect x="6" y="6" width="28" height="28" rx="2"/>
          <path d="M12 20h16M12 14h10M12 26h14"/>
        </svg>
      </div>
      <div>
        <div class="co-name">{{ cp.razonSocial }}</div>
      </div>
    </div>
    <div class="info">
      <p>{{ cp.direccion.direccion }} — {{ cp.direccion.distrito }}</p>
      <p>RUC <b>{{ cp.ruc }}</b></p>
    </div>
  </div>
  <div class="right">
    <div class="kind">Comunicación de Baja Electrónica</div>
    <div class="num">{{ doc.correlativo }}</div>
    <div class="rule"></div>
    <div class="row"><span class="k">Emisión</span><span class="v">{{ doc.fechaEmision|date('d/m/Y') }}</span></div>
    <div class="row"><span class="k">Referencia</span><span class="v">{{ doc.fechaReferencia|date('d/m/Y') }}</span></div>
  </div>
</div>

<div class="items-wrap">
<table class="items">
  <thead>
    <tr>
      <th class="c-idx">#</th>
      <th class="c-doc">Documento</th>
      <th class="c-doc">Tipo</th>
      <th>Motivo de Baja</th>
    </tr>
  </thead>
  <tbody>
    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx">{{ loop.index }}</td>
      <td class="c-doc">{{ det.serie }}-{{ det.numero|str_pad(8, '0', 'left') }}</td>
      <td class="c-doc">{{ det.tipoDocumento|catalog('01') }}</td>
      <td>{{ det.motivoBaja }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}
      <img src="data:image/png;base64,{{ qrBase64 }}" alt="QR" />
    {% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la Comunicación de Baja Electrónica.</p>
    <p>Este documento es una copia informativa del envío realizado a la SUNAT.</p>
    <p style="margin-top:6px;">Firmante: {{ cp.ruc }} · {{ cp.razonSocial }}</p>
    <p class="hash">Hash: {{ hashDocumento }}</p>
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">● CPE SUNAT</span>
  </div>
</div>

</body>
</html>
