<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.emisor %}
{% set cl = doc.receptor %}
{% set mon = doc.moneda|catalog('021') %}
{% set sym = doc.moneda|catalogAttr('021','simbolo') %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  body { font-family: 'Inter', sans-serif; font-size: 10.5px; line-height: 1.45; color: #0a0a0a; background: #fff; padding: 32px 36px; width: 794px; min-height: 1123px; }
  .mono { font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
  h1, h2, h3 { margin: 0; font-weight: 600; }
  p { margin: 0; }

  .masthead { display: grid; grid-template-columns: 1fr auto; align-items: start; gap: 24px; padding-bottom: 18px; border-bottom: 2px solid #0a0a0a; }
  .brand .mark { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .brand .mark .logo { width: 44px; height: 44px; color: #0a0a0a; }
  .brand .mark .name { font-size: 14px; font-weight: 700; letter-spacing: 0.02em; }
  .brand .meta { display: grid; grid-template-columns: 72px 1fr; column-gap: 16px; row-gap: 2px; font-size: 10px; margin: 0; }
  .brand .meta dt { text-transform: uppercase; letter-spacing: 0.08em; font-size: 9px; color: #737373; }
  .brand .meta dd { margin: 0; }

  .doc-id { text-align: right; min-width: 240px; }
  .doc-id .ruc { font-size: 10px; color: #737373; text-transform: uppercase; letter-spacing: 0.1em; }
  .doc-id .ruc strong { color: #0a0a0a; font-family: 'IBM Plex Mono', monospace; }
  .doc-id .kind { font-size: 16px; font-weight: 700; letter-spacing: 0.02em; margin-top: 2px; line-height: 1.15; }
  .doc-id .num { font-family: 'IBM Plex Mono', monospace; font-size: 22px; font-weight: 600; margin-top: 6px; letter-spacing: 0.04em; }
  .doc-id .issued { margin-top: 8px; font-size: 10px; color: #404040; }

  .ref { display: grid; grid-template-columns: auto 1fr auto; gap: 16px; align-items: center; padding: 14px 0; border-bottom: 1px solid #0a0a0a; }
  .ref .tag { border: 1px solid #0a0a0a; padding: 4px 10px; font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; font-weight: 600; }
  .ref .text { font-size: 11px; }
  .ref .text b { font-family: 'IBM Plex Mono', monospace; }
  .ref .amount { font-family: 'IBM Plex Mono', monospace; font-size: 16px; font-weight: 700; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; padding: 18px 0; border-bottom: 1px solid #0a0a0a; }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: #737373; margin-bottom: 6px; }
  .party .name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .party .row { display: flex; gap: 10px; font-size: 10px; margin-top: 2px; }
  .party .row span:first-child { color: #737373; min-width: 76px; text-transform: uppercase; letter-spacing: 0.06em; font-size: 9px; }

  .reason { padding: 16px 0; border-bottom: 1px solid #0a0a0a; }
  .reason .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: #737373; margin-bottom: 4px; }
  .reason .v { font-size: 13px; font-weight: 600; }
  .reason .desc { font-size: 10px; color: #404040; margin-top: 4px; max-width: 560px; }

  .items { width: 100%; border-collapse: collapse; margin-top: 16px; }
  .items thead th { font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; color: #737373; font-weight: 500; text-align: left; padding: 0 8px 8px 0; border-bottom: 1px solid #0a0a0a; }
  .items tbody td { padding: 11px 8px 11px 0; border-bottom: 1px dashed #d4d4d4; vertical-align: top; font-size: 10.5px; }
  .items .c-idx { width: 24px; color: #a3a3a3; }
  .items .c-code { width: 86px; }
  .items .c-qty, .items .c-price, .items .c-amt, .items .c-unit { text-align: right; }
  .items .c-unit { width: 46px; text-align: center; color: #737373; }
  .items .c-qty { width: 60px; }
  .items .c-price { width: 86px; }
  .items .c-amt { width: 90px; padding-right: 0; }
  .items .desc .main { font-weight: 500; }
  .items .desc .sub { font-size: 9.5px; color: #737373; margin-top: 2px; }

  .bottom { display: grid; grid-template-columns: 1fr 300px; gap: 32px; margin-top: 20px; }
  .notes .block { margin-bottom: 12px; }
  .notes .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: #737373; margin-bottom: 4px; }
  .notes .block .body { font-size: 10px; }
  .notes .small { font-size: 9.5px; color: #525252; }

  .totals .line { display: flex; justify-content: space-between; padding: 4px 0; font-size: 10.5px; }
  .totals .line .k { color: #525252; }
  .totals .line .v { font-family: 'IBM Plex Mono', monospace; white-space: nowrap; }
  .totals .rule { border-top: 1px solid #0a0a0a; margin: 4px 0; }
  .totals .grand { display: flex; justify-content: space-between; padding: 10px 0 4px; font-size: 15px; font-weight: 700; border-top: 2px solid #0a0a0a; margin-top: 4px; }
  .totals .grand .v { font-family: 'IBM Plex Mono', monospace; white-space: nowrap; }
  .totals .in-words { margin-top: 6px; padding: 8px 10px; background: #fafafa; border: 1px solid #e5e5e5; font-size: 10px; color: #404040; }

  .foot { display: grid; grid-template-columns: 90px 1fr auto; gap: 16px; align-items: start; margin-top: 22px; padding-top: 16px; border-top: 1px solid #0a0a0a; }
  .foot .qr { width: 90px; height: 90px; border: 1px solid #0a0a0a; padding: 4px; }
  .foot .qr img { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: #525252; }
  .foot .meta strong { color: #0a0a0a; }
  .foot .meta .hash { font-family: 'IBM Plex Mono', monospace; word-break: break-all; font-size: 9px; margin-top: 2px; }
  .foot .stamp { text-align: right; }
  .foot .stamp .badge { display: inline-block; border: 1px solid #0a0a0a; padding: 4px 10px; font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; }
  .foot .stamp .line { font-size: 9.5px; color: #525252; margin-top: 6px; max-width: 180px; }
</style>
</head>
<body>

<div class="masthead">
  <div class="brand">
    <div class="mark">
      {% if params.logo is not empty %}<img class="logo" src="{{ params.logo }}" alt="logo" style="object-fit:contain"/>{% else %}<svg class="logo" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="6" y="6" width="28" height="28" rx="3"/><path d="M12 20h16M12 14h10M12 26h14"/></svg>{% endif %}
      <div class="name">{{ doc.emisor.razonSocial }}</div>
    </div>
    <dl class="meta">
      <dt>Dirección</dt><dd>{{ doc.emisor.direccion.direccion }}</dd>
      {% if cp is not null and cp.contacto is not null %}<dt>Contacto</dt><dd>{{ cp.contacto.email }} · {{ cp.contacto.telefono }}</dd>{% endif %}
    </dl>
  </div>
  <div class="doc-id">
    <div class="ruc">RUC <strong>{{ doc.emisor.ruc }}</strong></div>
    <div class="kind">{{ name|upper }}</div>
    <div class="num">{{ doc.serie }} — {{ doc.numero|str_pad(8, '0', 'left') }}</div>
    <div class="issued">Emitido {{ doc.fechaEmision|date('dd/MM/yyyy') }} · {{ doc.fechaEmision|date('HH:mm:ss') }}</div>
  </div>
</div>

<div class="ref">
  <span class="tag">Incrementa</span>
  <div class="text">Aplica a <b>{{ doc.comprobanteAfectadoTipo|catalog('01') }} {{ doc.comprobanteAfectadoSerieNumero }}</b> — tipo de nota <b>{{ doc.tipoNota }} · {{ doc.tipoNota|catalog('10') }}</b>.</div>
  <div class="amount">+ {{ sym }} {{ doc.totalImporte.importeConImpuestos|n_format }}</div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Cliente</div>
    <div class="name">{{ doc.receptor.nombre }}</div>
    <div class="row"><span>{{ doc.receptor.tipoDocIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ doc.receptor.numDocIdentidad }}</span></div>
    {% if cl is not null and cl.direccion is not null %}
    <div class="row"><span>Dirección</span><span>{{ cl.direccion.direccion }}</span></div>
    {% endif %}
  </div>
  <div class="party">
    <div class="label">Documento referente</div>
    <div class="name">{{ doc.comprobanteAfectadoTipo|catalog('01') }} {{ doc.comprobanteAfectadoSerieNumero }}</div>
    <div class="row"><span>Emitida</span><span>{{ doc.fechaEmision|date('dd/MM/yyyy') }}</span></div>
    <div class="row"><span>Moneda</span><span>{{ mon }}{% if doc.tipoCambio is not null %} · T/C {{ doc.tipoCambio.venta }}{% endif %}</span></div>
  </div>
</div>

<div class="reason">
  <div class="head">Motivo de la nota · Código SUNAT {{ doc.tipoNota }}</div>
  <div class="v">{{ doc.tipoNota|catalog('10') }}</div>
  {% if doc.sustentoDescripcion is not empty %}<div class="desc">{{ doc.sustentoDescripcion }}</div>{% endif %}
</div>

<table class="items">
  <thead>
    <tr><th class="c-idx">#</th><th class="c-code">Código</th><th>Descripción</th><th class="c-unit">Und</th><th class="c-qty">Cant.</th><th class="c-price">P. Unit.</th><th class="c-amt">Importe</th></tr>
  </thead>
  <tbody>
    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codigoProducto }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div><div class="sub">{% if det.igvTipo %}{{ det.igvTipo|catalog('07') }}{% endif %}</div></td>
      <td class="c-unit">{{ det.unidadMedida }}</td>
      <td class="c-qty mono">{{ det.cantidad|n_format }}</td>
      <td class="c-price mono">{{ det.precio|n_format }}</td>
      <td class="c-amt mono">{{ (det.precio * det.cantidad)|n_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<div class="bottom">
  <div class="notes">
    {% if doc.sustentoDescripcion is not empty %}
    <div class="block">
      <div class="head">Sustento</div>
      <div class="body">
        <p>{{ doc.sustentoDescripcion }}</p>
      </div>
    </div>
    {% endif %}
    {% if doc.observaciones is not empty %}
    <div class="block">
      <div class="head">Observaciones</div>
      <div class="body">
        {% for obs in doc.observaciones|split('\n') %}<p class="small">· {{ obs }}</p>{% endfor %}
      </div>
    </div>
    {% endif %}
    <div class="block">
      <div class="head">Leyendas SUNAT</div>
      <div class="body">
        {% for entry in doc.leyendas %}{% if entry.key != '1000' %}<p class="small">· {{ entry.value }}</p>{% endif %}{% endfor %}
      </div>
    </div>
  </div>

  <div class="totals">
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.gravadoBaseImponible is not null %}
    <div class="line"><span class="k">Op. gravadas</span><span class="v">{{ sym }} {{ doc.totalImpuestos.gravadoBaseImponible|n_format }}</span></div>
    {% endif %}
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.exoneradoBaseImponible is not null %}
    <div class="line"><span class="k">Op. exoneradas</span><span class="v">{{ sym }} {{ doc.totalImpuestos.exoneradoBaseImponible|n_format }}</span></div>
    {% endif %}
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.inafectoBaseImponible is not null %}
    <div class="line"><span class="k">Op. inafectas</span><span class="v">{{ sym }} {{ doc.totalImpuestos.inafectoBaseImponible|n_format }}</span></div>
    {% endif %}
    <div class="rule"></div>
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.gravadoImporte is not null %}
    <div class="line"><span class="k">IGV (18%)</span><span class="v">{{ sym }} {{ doc.totalImpuestos.gravadoImporte|n_format }}</span></div>
    {% endif %}
    <div class="grand"><span>Total nota</span><span class="v">{{ sym }} {{ doc.totalImporte.importeConImpuestos|n_format }}</span></div>
    <div class="in-words">{% if doc.leyendas['1000'] %}Son: {{ doc.leyendas['1000'] }}{% endif %}</div>
  </div>
</div>

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}<img src="data:image/png;base64,{{ qrBase64 }}" alt="QR Code" />{% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la {{ name }}.</p>
    <p>Consulte la validez en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> con el RUC del emisor y el número del documento.</p>
    <p style="margin-top:6px;">Firmante: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    <p class="hash">Hash: {{ hashDocumento }}</p>
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">Nota aceptada</span>
    <div class="line">Documento electrónico que modifica el comprobante referenciado.</div>
  </div>
</div>

</body>
</html>
