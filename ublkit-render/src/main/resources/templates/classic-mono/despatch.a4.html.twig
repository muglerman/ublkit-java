<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.remitente %}
{% set cl = doc.destinatario %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  body { font-family: 'Inter', sans-serif; font-size: 10.5px; line-height: 1.45; color: #0a0a0a; background: #fff; padding: 32px 36px; width: 794px; min-height: 1123px; }
  .mono { font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
  h1, h2, h3 { margin: 0; font-weight: 600; }
  p { margin: 0; }

  .masthead { display: grid; grid-template-columns: 1fr auto; align-items: start; gap: 24px; padding-bottom: 18px; border-bottom: 2px solid #0a0a0a; }
  .brand .mark { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .brand .mark .logo { width: 44px; height: 44px; color: #0a0a0a; }
  .brand .mark .name { font-size: 14px; font-weight: 700; letter-spacing: 0.02em; }
  .brand .meta { display: grid; grid-template-columns: 96px 1fr; column-gap: 16px; row-gap: 2px; font-size: 10px; margin: 0; }
  .brand .meta dt { text-transform: uppercase; letter-spacing: 0.08em; font-size: 9px; color: #737373; }
  .brand .meta dd { margin: 0; }

  .doc-id { text-align: right; min-width: 250px; }
  .doc-id .ruc { font-size: 10px; color: #737373; text-transform: uppercase; letter-spacing: 0.1em; }
  .doc-id .ruc strong { color: #0a0a0a; font-family: 'IBM Plex Mono', monospace; }
  .doc-id .kind { font-size: 16px; font-weight: 700; letter-spacing: 0.02em; margin-top: 2px; line-height: 1.15; }
  .doc-id .sub { font-size: 10px; color: #525252; text-transform: uppercase; letter-spacing: 0.1em; }
  .doc-id .num { font-family: 'IBM Plex Mono', monospace; font-size: 22px; font-weight: 600; margin-top: 6px; letter-spacing: 0.04em; }
  .doc-id .issued { margin-top: 8px; font-size: 10px; color: #404040; }

  .route { display: grid; grid-template-columns: 1fr 28px 1fr; gap: 16px; align-items: center; padding: 16px 0; border-bottom: 1px solid #0a0a0a; }
  .route .leg .k { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: #737373; }
  .route .leg .v { font-size: 12px; font-weight: 600; margin-top: 2px; }
  .route .leg .a { font-size: 10px; color: #525252; margin-top: 1px; }
  .route .arrow { text-align: center; font-size: 20px; }
  .route .leg.right { text-align: right; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; padding: 18px 0; border-bottom: 1px solid #0a0a0a; }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: #737373; margin-bottom: 6px; }
  .party .name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .party .row { display: flex; gap: 10px; font-size: 10px; margin-top: 2px; }
  .party .row span:first-child { color: #737373; min-width: 70px; text-transform: uppercase; letter-spacing: 0.06em; font-size: 9px; }

  .strip { display: grid; grid-template-columns: repeat(4, 1fr); padding: 10px 0; border-bottom: 1px solid #0a0a0a; font-size: 10px; }
  .strip > div .k { display: block; font-size: 9px; color: #737373; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 2px; }
  .strip > div .v { color: #0a0a0a; font-weight: 500; }

  .twocol { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; padding: 16px 0; border-bottom: 1px solid #0a0a0a; }
  .twocol .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: #737373; margin-bottom: 6px; }
  .twocol .block .row { display: flex; gap: 10px; font-size: 10px; margin-top: 2px; }
  .twocol .block .row span:first-child { color: #737373; min-width: 86px; text-transform: uppercase; letter-spacing: 0.06em; font-size: 9px; }

  .items { width: 100%; border-collapse: collapse; margin-top: 16px; }
  .items thead th { font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; color: #737373; font-weight: 500; text-align: left; padding: 0 8px 8px 0; border-bottom: 1px solid #0a0a0a; }
  .items tbody td { padding: 10px 8px 10px 0; border-bottom: 1px dashed #d4d4d4; vertical-align: top; font-size: 10.5px; }
  .items .c-idx { width: 24px; color: #a3a3a3; }
  .items .c-code { width: 86px; }
  .items .c-qty, .items .c-unit { text-align: right; }
  .items .c-unit { width: 50px; text-align: center; color: #737373; }
  .items .c-qty { width: 70px; padding-right: 0; }
  .items .desc .main { font-weight: 500; }
  .items .desc .sub { font-size: 9.5px; color: #737373; margin-top: 2px; }

  .related { margin-top: 18px; padding: 12px 0; border-top: 1px solid #0a0a0a; border-bottom: 1px solid #0a0a0a; display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .related .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: #737373; margin-bottom: 5px; }
  .related .block .body { font-size: 10px; }
  .related .small { font-size: 9.5px; color: #525252; }

  .signs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
  .signs .box { border-top: 1px solid #0a0a0a; padding-top: 6px; text-align: center; font-size: 10px; }
  .signs .box .role { font-weight: 600; }
  .signs .box .meta { font-size: 9px; color: #737373; margin-top: 1px; }

  .foot { display: grid; grid-template-columns: 90px 1fr auto; gap: 16px; align-items: start; margin-top: 22px; padding-top: 16px; border-top: 2px solid #0a0a0a; }
  .foot .qr { width: 90px; height: 90px; border: 1px solid #0a0a0a; padding: 4px; }
  .foot .qr img { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: #525252; }
  .foot .meta strong { color: #0a0a0a; }
  .foot .meta .hash { font-family: 'IBM Plex Mono', monospace; word-break: break-all; font-size: 9px; margin-top: 2px; }
  .foot .stamp { text-align: right; }
  .foot .stamp .badge { display: inline-block; border: 1px solid #0a0a0a; padding: 4px 10px; font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; }
  .foot .stamp .line { font-size: 9.5px; color: #525252; margin-top: 6px; max-width: 180px; }
</style>
</head>
<body>

<div class="masthead">
  <div class="brand">
    <div class="mark">
      {% if params.logo is not empty %}<img class="logo" src="{{ params.logo }}" alt="logo" style="object-fit:contain"/>{% else %}<svg class="logo" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="6" y="6" width="28" height="28" rx="3"/><path d="M12 20h16M12 14h10M12 26h14"/></svg>{% endif %}
      <div class="name">{% if cp is not null %}{{ cp.razonSocial }}{% endif %}</div>
    </div>
    <dl class="meta">
      {% if cp is not null and cp.direccion is not null %}<dt>Dirección</dt><dd>{{ cp.direccion.direccion }}</dd>{% endif %}
      {% if cp is not null and cp.contacto is not null %}<dt>Contacto</dt><dd>{{ cp.contacto.email }} · {{ cp.contacto.telefono }}</dd>{% endif %}
    </dl>
  </div>
  <div class="doc-id">
    <div class="ruc">RUC <strong>{% if cp is not null %}{{ cp.ruc }}{% endif %}</strong></div>
    <div class="kind">{{ name|upper }} ELECTRÓNICA</div>
    <div class="num">{{ doc.serie }} — {{ doc.numero|str_pad(8, '0', 'left') }}</div>
    <div class="issued">Emitido {{ doc.fechaEmision|date('d/m/Y') }}{% if doc.horaEmision is not null %} · {{ doc.horaEmision }}{% endif %}</div>
  </div>
</div>

<div class="route">
  <div class="leg">
    <div class="k">Punto de partida</div>
    <div class="v">{% if doc.envio is not null and doc.envio.partida is not null %}{{ doc.envio.partida.direccion }}{% endif %}</div>
    <div class="a">{% if doc.envio is not null and doc.envio.partida is not null %}{% if params.partidaDistrito is not empty %}{{ params.partidaDistrito }} · {% endif %}Ubigeo {{ doc.envio.partida.ubigeo }}{% endif %}</div>
  </div>
  <div class="arrow">→</div>
  <div class="leg right">
    <div class="k">Punto de llegada</div>
    <div class="v">{% if doc.envio is not null and doc.envio.destino is not null %}{{ doc.envio.destino.direccion }}{% endif %}</div>
    <div class="a">{% if doc.envio is not null and doc.envio.destino is not null %}{% if params.destinoDistrito is not empty %}{{ params.destinoDistrito }} · {% endif %}Ubigeo {{ doc.envio.destino.ubigeo }}{% endif %}</div>
  </div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Destinatario</div>
    {% if cl is not null %}
    <div class="name">{{ cl.nombre }}</div>
    <div class="row"><span>{{ cl.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ cl.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
  </div>
  <div class="party">
    <div class="label">Documento relacionado</div>
    {% if doc.documentosRelacionados is not empty %}
    {% for rel in doc.documentosRelacionados %}
    <div class="row"><span>{{ rel.tipoDocumento }}</span><span class="mono">{{ rel.serieNumero }}</span></div>
    {% endfor %}
    {% endif %}
  </div>
</div>

<div class="strip">
  <div><span class="k">Inicio traslado</span><span class="v">{% if doc.envio is not null and doc.envio.fechaTraslado is not null %}{{ doc.envio.fechaTraslado|date('d/m/Y') }}{% endif %}</span></div>
  <div><span class="k">Motivo</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.tipoTraslado }} · {{ doc.envio.tipoTraslado|catalog('20') }}{% endif %}</span></div>
  <div><span class="k">Modalidad</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.tipoModalidadTraslado }} · {{ doc.envio.tipoModalidadTraslado|catalog('18') }}{% endif %}</span></div>
  <div><span class="k">Peso · bultos</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.pesoTotal }} {{ doc.envio.pesoTotalUnidadMedida }}{% if doc.envio.numeroDeBultos is not null %} · {{ doc.envio.numeroDeBultos }}{% endif %}{% endif %}</span></div>
  <div><span class="k">Estado de pago</span><span class="v">{% if params.estadoPago is not empty %}{{ params.estadoPago }}{% endif %}</span></div><div><span class="k">Nro. taquito</span><span class="v">{% if params.trackingNumber is not empty %}{{ params.trackingNumber }}{% endif %}</span></div><div><span class="k">Total</span><span class="v">{% if params.totalGuia is not empty %}{{ params.totalGuia|n_format }}{% endif %}</span></div>
</div>

<div class="twocol">
  <div class="block">
    <div class="head">Transporte</div>
    {% if doc.envio is not null and doc.envio.transportista is not null %}
    <div class="row"><span>Transportista</span><span>{{ doc.envio.transportista.nombre }}</span></div>
    <div class="row"><span>RUC Transp.</span><span class="mono">{{ doc.envio.transportista.numeroDocumentoIdentidad }}</span></div>
    {% if doc.envio.transportista.numeroRegistroMTC is not empty %}
    <div class="row"><span>Registro MTC</span><span class="mono">{{ doc.envio.transportista.numeroRegistroMTC }}</span></div>
    {% endif %}
    {% endif %}
    {% if doc.subcontratado is not null %}
    <div class="row"><span>Subcontratado</span><span>{{ doc.subcontratado.nombre }}{% if doc.subcontratado.numeroDocumentoIdentidad is not empty %} · {{ doc.subcontratado.numeroDocumentoIdentidad }}{% endif %}</span></div>
    {% endif %}
    {% if doc.envio is not null and doc.envio.vehiculo is not null %}
    <div class="row"><span>Placa</span><span class="mono">{{ doc.envio.vehiculo.placa }}</span></div>
    {% if doc.envio.vehiculo.numeroCirculacion is not empty %}
    <div class="row"><span>TUC/CHV</span><span class="mono">{{ doc.envio.vehiculo.numeroCirculacion }}</span></div>
    {% endif %}
    {% endif %}
  </div>
  <div class="block">
    <div class="head">Conductor</div>
    {% if doc.envio is not null and doc.envio.choferes is not empty %}
    <div class="row"><span>Nombres</span><span>{{ doc.envio.choferes[0].nombres }} {{ doc.envio.choferes[0].apellidos }}</span></div>
    <div class="row"><span>{{ doc.envio.choferes[0].tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ doc.envio.choferes[0].numeroDocumentoIdentidad }}</span></div>
    {% if doc.envio.choferes[0].licencia is not empty %}
    <div class="row"><span>Brevete</span><span class="mono">{{ doc.envio.choferes[0].licencia }}</span></div>
    {% endif %}
    {% endif %}
  </div>
</div>

<table class="items">
  <thead>
    <tr><th class="c-idx">#</th><th class="c-code">Código</th><th>Descripción del bien</th><th class="c-unit">Und</th><th class="c-qty">Cantidad</th></tr>
  </thead>
  <tbody>
    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codigo }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div></td>
      <td class="c-unit">{{ det.unidadMedida }}</td>
      <td class="c-qty mono">{{ det.cantidad|n_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
  {% if params.totalGuia is not empty and params.totalGuia > 0 %}<tfoot><tr><td colspan="99" style="text-align:right;padding:10px 12px;font-weight:700;">Monto total: S/ {{ params.totalGuia|n_format }}</td></tr></tfoot>{% endif %}
</table>

{% if doc.documentosRelacionados is not empty or doc.observaciones is not empty %}
<div class="related">
  <div class="block">
    <div class="head">Documentos relacionados</div>
    <div class="body">
      {% for rel in doc.documentosRelacionados %}
      <p>{{ rel.tipoDocumento }} · <span class="mono">{{ rel.serieNumero }}</span></p>
      {% endfor %}
    </div>
  </div>
  <div class="block">
    <div class="head">Observaciones</div>
    <div class="body">
      {% if doc.observaciones is not empty %}{% for obs in doc.observaciones|split('\n') %}<p class="small">· {{ obs }}</p>{% endfor %}{% endif %}
    </div>
  </div>
</div>
{% endif %}

<div class="signs">
  <div class="box"><div class="role">Remitente</div><div class="meta">{% if cp is not null %}{{ cp.razonSocial }}{% endif %}</div></div>
  <div class="box"><div class="role">Conductor</div><div class="meta">{% if doc.envio is not null and doc.envio.choferes is not empty %}{{ doc.envio.choferes[0].nombres }} {{ doc.envio.choferes[0].apellidos }} · {{ doc.envio.choferes[0].tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }} {{ doc.envio.choferes[0].numeroDocumentoIdentidad }}{% endif %}</div></div>
  <div class="box"><div class="role">Recepción / Destinatario</div><div class="meta">{% if cl is not null %}{{ cl.nombre }}{% endif %}</div></div>
</div>

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}<img src="data:image/png;base64,{{ qrBase64 }}" alt="QR Code" />{% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la Guía de Remisión Remitente Electrónica.</p>
    <p>Consulte la validez en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> con el RUC del remitente y el número del documento.</p>
    <p style="margin-top:6px;">Firmante: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    {% if hashDocumento is not empty %}<p class="hash">Hash: {{ hashDocumento }}</p>{% endif %}
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">GRE-R válida</span>
    <div class="line">Documento electrónico emitido conforme a la RS SUNAT 271-2019.</div>
  </div>
</div>

</body>
</html>
