<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.remitente %}
{% set cl = doc.destinatario %}
{% set name = doc.tipoComprobante|catalog("01") %}
<title>T001-0001287 · Guía De Remisión Electrónica</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  body {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    line-height: 1.45;
    color: #0a0a0a;
    background: #fff;
    padding: 24px;
    width: 794px;
    min-height: 559px;
  }
  .mono { font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
  h1, h2, h3 { margin: 0; font-weight: 600; }
  p { margin: 0; }

  .masthead { display: grid; grid-template-columns: 1fr auto; align-items: start; gap: 24px; padding-bottom: 18px; border-bottom: 2px solid #0a0a0a; }
  .brand .mark { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .brand .mark .logo { width: 56px; height: 56px; color: #0a0a0a; }
  .brand .mark .name { font-size: 13px; font-weight: 700; letter-spacing: 0.02em; }
  .brand .meta { display: grid; grid-template-columns: 72px 1fr; column-gap: 16px; row-gap: 2px; font-size: 10px; margin: 0; }
  .brand .meta dt { text-transform: uppercase; letter-spacing: 0.08em; font-size: 9px; color: #737373; }
  .brand .meta dd { margin: 0; color: #0a0a0a; }

  .doc-id { text-align: right; min-width: 240px; }
  .doc-id .ruc { font-size: 10px; color: #737373; text-transform: uppercase; letter-spacing: 0.1em; }
  .doc-id .ruc strong { color: #0a0a0a; font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.02em; }
  .doc-id .kind { font-size: 18px; font-weight: 700; letter-spacing: 0.04em; margin-top: 2px; line-height: 1.15; }
  .doc-id .num { font-family: 'IBM Plex Mono', monospace; font-size: 22px; font-weight: 600; margin-top: 6px; letter-spacing: 0.04em; }
  .doc-id .issued { margin-top: 8px; font-size: 10px; color: #404040; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; padding: 18px 0; border-bottom: 1px solid #0a0a0a; }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: #737373; margin-bottom: 6px; }
  .party .name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .party .row { display: flex; gap: 10px; font-size: 10px; margin-top: 2px; }
  .party .row span:first-child { color: #737373; min-width: 68px; text-transform: uppercase; letter-spacing: 0.06em; font-size: 9px; }
  .party .row span:last-child { color: #0a0a0a; }

  .strip { display: grid; grid-template-columns: repeat(4, 1fr); padding: 10px 0; border-bottom: 1px solid #0a0a0a; font-size: 10px; }
  .strip > div .k { display: block; font-size: 9px; color: #737373; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 2px; }
  .strip > div .v { color: #0a0a0a; font-weight: 500; }

  .items { width: 100%; border-collapse: collapse; margin-top: 16px; }
  .items thead th { font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; color: #737373; font-weight: 500; text-align: left; padding: 0 0 8px 0; border-bottom: 1px solid #0a0a0a; }
  .items tbody td { padding: 10px 0; border-bottom: 1px dashed #d4d4d4; vertical-align: top; font-size: 9px; }
  .items .c-idx { width: 24px; color: #a3a3a3; }
  .items .c-code { width: 86px; padding-right: 8px; }
  .items .c-qty, .items .c-price, .items .c-tax, .items .c-unit { text-align: right; }
  .items .c-qty { width: 60px; padding-right: 8px; }
  .items .c-unit { width: 46px; text-align: center; color: #737373; padding-right: 8px; }
  .items .c-price { width: 82px; padding-right: 8px; }
  .items .c-tax { width: 82px; }
  .items .desc .main { font-weight: 500; padding-right: 10px; }
  .items .desc .sub { font-size: 9.5px; color: #737373; margin-top: 2px; }

  .bottom { display: grid; grid-template-columns: 1fr 320px; gap: 32px; margin-top: 20px; }
  .notes .block { margin-bottom: 12px; }
  .notes .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: #737373; margin-bottom: 4px; }
  .notes .block .body { font-size: 10px; color: #0a0a0a; }
  .notes .block .body p + p { margin-top: 2px; }
  .notes .small { font-size: 9.5px; color: #525252; }

  .totals .line { display: flex; justify-content: space-between; padding: 4px 0; font-size: 9px; }
  .totals .line .k { color: #525252; }
  .totals .line .v { font-family: 'IBM Plex Mono', monospace; white-space: nowrap; }
  .totals .rule { border-top: 1px solid #0a0a0a; margin: 4px 0; }
  .totals .grand { display: flex; justify-content: space-between; padding: 10px 0 4px; font-size: 15px; font-weight: 700; border-top: 2px solid #0a0a0a; margin-top: 4px; }
  .totals .grand .v { font-family: 'IBM Plex Mono', monospace; white-space: nowrap; }
  .totals .in-words { margin-top: 6px; padding: 8px 10px; background: #fafafa; border: 1px solid #e5e5e5; font-size: 10px; color: #404040; }

  .foot { display: grid; grid-template-columns: 90px 1fr auto; gap: 16px; align-items: start; margin-top: 22px; padding-top: 16px; border-top: 1px solid #0a0a0a; }
  .foot .qr { width: 90px; height: 90px; border: 1px solid #0a0a0a; padding: 4px; }
  .foot .qr svg { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: #525252; }
  .foot .meta strong { color: #0a0a0a; }
  .foot .meta .hash { font-family: 'IBM Plex Mono', monospace; word-break: break-all; font-size: 9px; margin-top: 2px; }
  .foot .stamp { text-align: right; }
  .foot .stamp .badge { display: inline-block; border: 1px solid #0a0a0a; padding: 4px 10px; font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; }
  .foot .stamp .line { font-size: 9.5px; color: #525252; margin-top: 6px; max-width: 180px; }
  .foot .stamp .barcode { margin-top: 8px; display: flex; gap: 1.5px; justify-content: flex-end; height: 22px; align-items: end; }
  .foot .stamp .barcode i { background: #0a0a0a; display: block; height: 100%; }
</style>
</head>
<body>

<div class="masthead">
  <div class="brand">
    <div class="mark">
      {% if params.logo is not empty %}<img class="logo" src="{{ params.logo }}" alt="logo" style="object-fit:contain"/>{% else %}<svg class="logo" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.2">
        <rect x="6" y="6" width="28" height="28" rx="3"/>
        <path d="M12 20h16M12 14h10M12 26h14"/>
      </svg>{% endif %}
      <div class="name">{% if cp is not null %}{{ cp.razonSocial }}{% endif %}</div>
    </div>
    <dl class="meta">
      <dt>Dirección</dt><dd>{% if cp is not null and cp.direccion is not null %}{{ cp.direccion.direccion }}{% endif %}</dd>
      <dt>Contacto</dt><dd>{% if cp is not null and cp.contacto is not null %}{% if cp.contacto.email is not empty %}{{ cp.contacto.email }}{% endif %}{% if cp.contacto.email is not empty and cp.contacto.telefono is not empty %} · {% endif %}{{ cp.contacto.telefono }}{% endif %}</dd>
    </dl>
  </div>
  <div class="doc-id">
    <div class="ruc">RUC <strong>{% if cp is not null %}{{ cp.ruc }}{% endif %}</strong></div>
    <div class="kind">{% if doc.tipoComprobante is not empty %}{{ name|upper }} ELECTRÓNICA{% else %}GUÍA DE REMISIÓN ELECTRÓNICA{% endif %}</div>
    <div class="num">{{ doc.serie }} — {{ doc.numero|str_pad(8, '0', 'left') }}</div>
    <div class="issued">Emitido {{ doc.fechaEmision|date('d/m/Y') }}{% if doc.horaEmision is not null %} · {{ doc.horaEmision }}{% endif %}</div>
  </div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Destinatario</div>
    <div class="name">{% if cl is not null %}{{ cl.nombre }}{% endif %}</div>
    <div class="row"><span>{% if cl is not null %}{{ cl.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}{% endif %}</span><span class="mono">{% if cl is not null %}{{ cl.numeroDocumentoIdentidad }}{% endif %}</span></div>
    {% if doc.envio is not null and doc.envio.destino is not null %}
    <div class="row"><span>Llegada</span><span>{{ doc.envio.destino.direccion }}</span></div>
    <div class="row"><span>Ubigeo</span><span>{{ doc.envio.destino.ubigeo }}</span></div>
    {% endif %}
  </div>
  <div class="party">
    <div class="label">Envío</div>
    {% if doc.envio is not null %}
    {% if doc.envio.partida is not null %}<div class="row"><span>Partida</span><span>{{ doc.envio.partida.direccion }}</span></div>{% endif %}
    {% if doc.envio.transportista is not null %}<div class="row"><span>Transporte</span><span>{{ doc.envio.transportista.nombre }}{% if doc.envio.transportista.numeroDocumentoIdentidad is not empty %} · {{ doc.envio.transportista.numeroDocumentoIdentidad }}{% endif %}</span></div>{% endif %}
    {% if doc.envio.transportista is not null and doc.envio.transportista.numeroRegistroMTC is not empty %}<div class="row"><span>Registro MTC</span><span class="mono">{{ doc.envio.transportista.numeroRegistroMTC }}</span></div>{% endif %}
    {% if doc.subcontratado is not null %}<div class="row"><span>Transp. subcontratado</span><span>{{ doc.subcontratado.nombre }}{% if doc.subcontratado.numeroDocumentoIdentidad is not empty %} · {{ doc.subcontratado.numeroDocumentoIdentidad }}{% endif %}</span></div>{% endif %}
    {% if doc.envio.vehiculo is not null %}<div class="row"><span>Vehículo</span><span class="mono">{{ doc.envio.vehiculo.placa }}</span></div>{% endif %}
    {% endif %}
  </div>
</div>

<div class="strip">
  <div><span class="k">Inicio traslado</span><span class="v">{% if doc.envio is not null and doc.envio.fechaTraslado is not null %}{{ doc.envio.fechaTraslado|date('d/m/Y') }}{% endif %}</span></div>
  <div><span class="k">Motivo</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.tipoTraslado|catalog('20') }}{% endif %}</span></div>
  <div><span class="k">Modalidad</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.tipoModalidadTraslado|catalog('18') }}{% endif %}</span></div>
  <div><span class="k">Peso / bultos</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.pesoTotal }} {{ doc.envio.pesoTotalUnidadMedida }} · {{ doc.envio.numeroDeBultos }}{% endif %}</span></div>
</div>

<table class="items">
  <thead>
    <tr>
      <th class="c-idx">#</th>
      <th class="c-code">Código</th>
      <th>Descripción</th>
      <th class="c-unit">Und</th>
      <th class="c-qty">Cant.</th></tr>
  </thead>
  <tbody>

    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codigo }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div></td>
      <td class="c-unit">{{ det.unidadMedida }}</td>
      <td class="c-qty mono">{{ det.cantidad }}</td>
    </tr>
    {% endfor %}
  </tbody>
  {% if params.totalGuia is not empty and params.totalGuia > 0 %}<tfoot><tr><td colspan="99" style="text-align:right;padding:10px 12px;font-weight:700;">Monto total: S/ {{ params.totalGuia|n_format }}</td></tr></tfoot>{% endif %}
</table>

<div class="foot">
  <div class="qr">
    <img src="data:image/svg+xml;base64,{{ qrBase64 }}" />
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la Guía De Remisión Electrónica.</p>
    <p>Consulte la validez en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> usando el RUC del emisor y el número del documento.</p>
    <p style="margin-top:6px;">Firmante: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    <p class="hash">Resumen: {{ hashDocumento }}</p>
  </div>
  <div class="stamp">
    <span class="badge">CPE válido</span>
    <div class="line">Documento electrónico emitido conforme al RCP SUNAT.</div>
    <div class="barcode">
      <i style="width:2px"></i><i style="width:1px"></i><i style="width:3px"></i><i style="width:1px"></i><i style="width:2px"></i><i style="width:2px"></i><i style="width:1px"></i><i style="width:3px"></i><i style="width:1px"></i><i style="width:2px"></i><i style="width:1px"></i><i style="width:3px"></i><i style="width:2px"></i><i style="width:1px"></i><i style="width:2px"></i><i style="width:1px"></i><i style="width:3px"></i><i style="width:1px"></i><i style="width:2px"></i><i style="width:2px"></i><i style="width:1px"></i><i style="width:3px"></i><i style="width:1px"></i><i style="width:2px"></i><i style="width:1px"></i><i style="width:3px"></i><i style="width:2px"></i><i style="width:1px"></i>
    </div>
  </div>
</div>

</body>
</html>
