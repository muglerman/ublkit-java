<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.remitente %}
{% set tercero = doc.tercero %}
{% set cl = doc.destinatario %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root { --ink: #0b1f3a; --ink-2: #334a6b; --ink-3: #6b7e96; --accent: #1e4694; --accent-soft: #eef3fb; --line: #d6dde8; }
  body { font-family: 'Inter', sans-serif; font-size: 10.5px; line-height: 1.45; color: var(--ink); background: #fff; width: 794px; min-height: 1123px; }
  .mono { font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
  p, h1, h2, h3 { margin: 0; }

  .band { background: var(--accent); color: #fff; padding: 22px 36px; display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: center; }
  .band .logo-block { display: flex; align-items: center; gap: 14px; }
  .band .logo { width: 58px; height: 58px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .band .logo svg { width: 30px; height: 30px; }
  .band .logo img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; }
  .band .co-name { font-size: 15px; font-weight: 700; }
  .band .co-sub { font-size: 10.5px; opacity: 0.82; margin-top: 2px; }
  .band .docbox { background: #fff; color: var(--ink); border-radius: 10px; padding: 14px 18px; min-width: 260px; text-align: right; }
  .band .docbox .ruc { font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.12em; }
  .band .docbox .ruc b { color: var(--ink); }
  .band .docbox .kind { font-size: 13px; font-weight: 700; color: var(--accent); margin-top: 4px; letter-spacing: 0.02em; }
  .band .docbox .sub { font-size: 9.5px; color: var(--ink-3); }
  .band .docbox .num { font-family: 'IBM Plex Mono', monospace; font-size: 22px; font-weight: 600; margin-top: 2px; }

  .body-wrap { padding: 22px 36px 28px; }

  .route { background: var(--accent-soft); border: 1px solid #d3e0f3; border-radius: 8px; padding: 16px 20px; display: grid; grid-template-columns: 1fr auto 1fr; gap: 18px; align-items: center; margin-bottom: 18px; }
  .route .leg .k { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 600; }
  .route .leg .v { font-size: 12.5px; font-weight: 700; margin-top: 2px; }
  .route .leg .a { font-size: 10px; color: var(--ink-2); margin-top: 1px; }
  .route .arrow { font-size: 22px; color: var(--accent); }
  .route .leg.right { text-align: right; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .party { border: 1px solid var(--line); border-radius: 8px; padding: 14px 16px; }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 600; margin-bottom: 6px; }
  .party .name { font-size: 11px; font-weight: 600; margin-bottom: 6px; }
  .party .row { display: grid; grid-template-columns: 80px 1fr; font-size: 10px; padding: 1px 0; }
  .party .row .k { color: var(--ink-3); }

  .strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 16px; }
  .strip .chip { background: #f4f7fc; border: 1px solid var(--line); border-radius: 8px; padding: 9px 12px; }
  .strip .chip .k { font-size: 9px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 2px; }
  .strip .chip .v { font-size: 11px; font-weight: 600; }

  .items { width: 100%; border-collapse: separate; border-spacing: 0; border: 1px solid var(--line); border-radius: 8px; overflow: hidden; }
  .items thead th { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.08em; color: #fff; font-weight: 600; background: var(--ink); text-align: left; padding: 10px; }
  .items tbody td { padding: 10px; border-top: 1px solid var(--line); vertical-align: top; font-size: 10.5px; }
  .items tbody tr:first-child td { border-top: 0; }
  .items tbody tr:nth-child(even) td { background: #f8fafd; }
  .items .c-idx { width: 28px; color: var(--ink-3); text-align: center; }
  .items .c-code { width: 90px; }
  .items .c-qty { text-align: right; width: 80px; }
  .items .c-unit { width: 50px; text-align: center; color: var(--ink-3); }
  .items .desc .main { font-weight: 500; }
  .items .desc .sub { font-size: 9.5px; color: var(--ink-3); margin-top: 2px; }

  .transport { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 16px; }
  .transport .card { border: 1px solid var(--line); border-radius: 8px; padding: 14px 16px; }
  .transport .card .head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .transport .card .head .icon { width: 24px; height: 24px; background: var(--accent-soft); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: var(--accent); }
  .transport .card .head .title { font-size: 11px; font-weight: 700; }
  .transport .card .row { display: grid; grid-template-columns: 84px 1fr; font-size: 10px; padding: 1.5px 0; }
  .transport .card .row .k { color: var(--ink-3); }

  .related { background: #f4f7fc; border: 1px solid var(--line); border-radius: 8px; padding: 14px 18px; margin-top: 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .related .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 600; margin-bottom: 4px; }
  .related .block .body { font-size: 10px; }
  .related .small { font-size: 9.5px; color: var(--ink-2); }

  .foot { display: grid; grid-template-columns: 100px 1fr auto; gap: 18px; align-items: start; margin-top: 22px; padding-top: 14px; border-top: 2px solid var(--ink); }
  .foot .qr { width: 100px; height: 100px; background: #fff; padding: 4px; border: 1px solid var(--line); border-radius: 6px; }
  .foot .qr img { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: var(--ink-2); }
  .foot .meta strong { color: var(--ink); }
  .foot .meta .hash { font-family: 'IBM Plex Mono', monospace; word-break: break-all; font-size: 8.5px; margin-top: 2px; }
  .foot .stamp { text-align: right; min-width: 180px; }
  .foot .stamp .badge { display: inline-block; background: var(--accent-soft); color: var(--accent); padding: 5px 12px; border-radius: 999px; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; }
  .foot .stamp .line { font-size: 9.5px; color: var(--ink-2); margin-top: 8px; max-width: 180px; }
</style>
</head>
<body>

<div class="band">
  <div class="logo-block">
    <div class="logo">{% if params.logo is not empty %}<img src="{{ params.logo }}" alt="logo"/>{% else %}<svg viewBox="0 0 40 40" fill="none" stroke="#fff" stroke-width="2.4"><circle cx="20" cy="20" r="14"/><path d="M9 23l5-9 6 4 6-7"/></svg>{% endif %}</div>
    <div>
      <div class="co-name">{% if cp is not null %}{{ cp.razonSocial }}{% endif %}</div>
      <div class="co-sub">{% if cp is not null and cp.direccion is not null %}{{ cp.direccion.direccion }}{% endif %}{% if doc.subcontratado is not null %} · Subcontratado: {{ doc.subcontratado.nombre }}{% endif %}{% if cp is not null and cp.contacto is not null %} · {{ cp.contacto.telefono }}{% endif %}</div>
      {% if doc.envio is not null and doc.envio.transportista is not null and doc.envio.transportista.numeroRegistroMTC is not empty %}<div class="co-sub">Reg. MTC {{ doc.envio.transportista.numeroRegistroMTC }}</div>{% endif %}
    </div>
  </div>
  <div class="docbox">
    <div class="ruc">R.U.C. <b class="mono">{% if cp is not null %}{{ cp.ruc }}{% endif %}</b></div>
    <div class="kind">{{ name|upper }} ELECTRÓNICA</div>
    <div class="num">{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }}</div>
  </div>
</div>

<div class="body-wrap">

<div class="route">
  <div class="leg">
    <div class="k">Punto de partida</div>
    <div class="v">{% if doc.envio is not null and doc.envio.partida is not null %}{{ doc.envio.partida.direccion }}{% endif %}</div>
    <div class="a">{% if params.partidaDistrito is not empty %}{% if params.partidaDepartamento is not empty %}{{ params.partidaDepartamento }} — {{ params.partidaProvincia }} — {% endif %}{{ params.partidaDistrito }}{% endif %}{% if doc.envio is not null and doc.envio.partida is not null and doc.envio.partida.ubigeo is not empty %} · Ubigeo {{ doc.envio.partida.ubigeo }}{% endif %}</div>
  </div>
  <div class="arrow">→</div>
  <div class="leg right">
    <div class="k">Punto de llegada</div>
    <div class="v">{% if doc.envio is not null and doc.envio.destino is not null %}{{ doc.envio.destino.direccion }}{% endif %}</div>
    <div class="a">{% if params.destinoDistrito is not empty %}{% if params.destinoDepartamento is not empty %}{{ params.destinoDepartamento }} — {{ params.destinoProvincia }} — {% endif %}{{ params.destinoDistrito }}{% endif %}{% if doc.envio is not null and doc.envio.destino is not null and doc.envio.destino.ubigeo is not empty %} · Ubigeo {{ doc.envio.destino.ubigeo }}{% endif %}</div>
  </div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Remitente</div>
    {% if tercero is not null %}
    <div class="name">{{ tercero.nombre }}</div>
    <div class="row"><span class="k">{{ tercero.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ tercero.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
  </div>
  <div class="party">
    <div class="label">Destinatario</div>
    {% if cl is not null %}
    <div class="name">{{ cl.nombre }}</div>
    <div class="row"><span class="k">{{ cl.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ cl.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
  </div>
</div>

<div class="strip">
  <div class="chip"><span class="k">Inicio traslado</span><span class="v">{% if doc.envio is not null and doc.envio.fechaTraslado is not null %}{{ doc.envio.fechaTraslado|date('d/m/Y') }}{% endif %}</span></div>
  <div class="chip"><span class="k">Modalidad</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.tipoModalidadTraslado|catalog('18') }}{% endif %}</span></div>
  <div class="chip"><span class="k">Peso bruto</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.pesoTotal }} {{ doc.envio.pesoTotalUnidadMedida }}{% endif %}</span></div>
  <div class="chip"><span class="k">Bultos</span><span class="v">{% if doc.envio is not null and doc.envio.numeroDeBultos is not null %}{{ doc.envio.numeroDeBultos }}{% endif %}</span></div>
  <div class="chip"><span class="k">Estado de pago</span><span class="v">{% if params.estadoPago is not empty %}{{ params.estadoPago }}{% endif %}</span></div><div class="chip"><span class="k">Nro. taquito</span><span class="v">{% if params.trackingNumber is not empty %}{{ params.trackingNumber }}{% endif %}</span></div>
</div>

<table class="items">
  <thead>
    <tr><th class="c-idx">#</th><th class="c-code">Código</th><th>Descripción del bien</th><th class="c-unit">Und</th><th class="c-qty">Cant.</th></tr>
  </thead>
  <tbody>
    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codigo }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div></td>
      <td class="c-unit">{{ det.unidadMedida }}</td>
      <td class="c-qty mono">{{ det.cantidad|q_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
  {% if params.totalGuia is not empty and params.totalGuia > 0 %}<tfoot><tr><td colspan="99" style="text-align:right;padding:10px 12px;font-weight:700;">Monto total: S/ {{ params.totalGuia|n_format }}</td></tr></tfoot>{% endif %}
</table>

<div class="transport">
  <div class="card">
    <div class="head"><div class="icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 17V7h13l5 5v5M3 17h2M9 17h10M5 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm14 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></svg></div><div class="title">Vehículos</div></div>
    {% if doc.envio is not null and doc.envio.vehiculo is not null %}
    <div class="row"><span class="k">Placa principal</span><span class="mono">{{ doc.envio.vehiculo.placa }}</span></div>
    {% if doc.envio.vehiculo.numeroCirculacion is not empty %}
    <div class="row"><span class="k">TUC/CHV</span><span class="mono">{{ doc.envio.vehiculo.numeroCirculacion }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.marca is not empty %}
    <div class="row"><span class="k">Marca</span><span>{{ doc.envio.vehiculo.marca }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.modelo is not empty %}
    <div class="row"><span class="k">Modelo</span><span>{{ doc.envio.vehiculo.modelo }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.numeroAutorizacion is not empty %}
    <div class="row"><span class="k">Autorización</span><span class="mono">{{ doc.envio.vehiculo.numeroAutorizacion }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.secundarios is not empty %}{% for v in doc.envio.vehiculo.secundarios %}<div class="row"><span class="k">Placa secundaria</span><span class="mono">{{ v.placa }}{% if v.numeroCirculacion is not empty %} · TUC {{ v.numeroCirculacion }}{% endif %}</span></div>{% endfor %}{% endif %}
    {% endif %}
  </div>
  <div class="card">
    <div class="head"><div class="icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg></div><div class="title">Conductores</div></div>
    {% if doc.envio is not null and doc.envio.choferes is not empty %}{% for ch in doc.envio.choferes %}
    <div class="row"><span class="k">{% if loop.first %}Principal{% else %}Secundario{% endif %}</span><span>{{ ch.nombres }} {{ ch.apellidos }}</span></div>
    <div class="row"><span class="k">{{ ch.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }} · Brevete</span><span class="mono">{{ ch.numeroDocumentoIdentidad }}{% if ch.licencia is not empty %} · {{ ch.licencia }}{% endif %}</span></div>
    {% endfor %}{% endif %}
  </div>
</div>

{% if doc.documentosRelacionados is not empty or doc.observaciones is not empty %}
<div class="related">
  {% if doc.documentosRelacionados is not empty %}
  <div class="block">
    <div class="head">Documentos relacionados</div>
    <div class="body">
      {% for rel in doc.documentosRelacionados %}
      <p>{{ rel.tipoDocumento }} · <span class="mono">{{ rel.serieNumero }}</span></p>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  {% if doc.observaciones is not empty %}
  <div class="block">
    <div class="head">Observaciones</div>
    <div class="body">
      {% for obs in doc.observaciones|split('\n') %}<p class="small">· {{ obs }}</p>{% endfor %}
    </div>
  </div>
  {% endif %}
</div>
{% endif %}

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}<img src="data:image/png;base64,{{ qrBase64 }}" alt="QR Code" />{% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la Guía de Remisión Transportista Electrónica.</p>
    <p>Consulte la validez en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> con el RUC del transportista y el número del documento.</p>
    <p style="margin-top:6px;">Firmante: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    {% if hashDocumento is not empty %}<p class="hash">Hash: {{ hashDocumento }}</p>{% endif %}
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">● GRE-T autorizada</span>
    <div class="line">Documento electrónico emitido conforme a la RS SUNAT 271-2019.</div>
  </div>
</div>

</div>
</body>
</html>
