<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>{{ doc.numero }} · Manifiesto de Carga</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root { --ink: #0b1f3a; --ink-2: #334a6b; --ink-3: #6b7e96; --accent: #1e4694; --accent-soft: #eef3fb; --line: #d6dde8; }
  body { font-family: 'Inter', sans-serif; font-size: 10px; line-height: 1.4; color: var(--ink); background: #fff; width: 1123px; min-height: 794px; }
  .mono { font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
  p { margin: 0; }

  .band { background: var(--accent); color: #fff; padding: 16px 38px; display: grid; grid-template-columns: 1fr 300px; gap: 20px; align-items: center; }
  .band .logo-block { display: flex; align-items: center; gap: 12px; }
  .band .logo { width: 42px; height: 42px; flex: none; background: rgba(255,255,255,.14); border-radius: 9px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .band .logo svg { width: 25px; height: 25px; }
  .band .logo img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .band .co-name { font-size: 15px; font-weight: 700; }
  .band .co-sub { font-size: 9px; opacity: 0.82; margin-top: 2px; }
  .band .docbox { background: #fff; color: var(--ink); border-radius: 9px; padding: 11px 14px; }
  .band .docbox .kind { font-size: 12px; font-weight: 800; color: var(--accent); }
  .band .docbox .sub { font-size: 8px; color: var(--ink-3); }
  .band .docbox .num { font-family: 'IBM Plex Mono', monospace; font-size: 17px; font-weight: 600; margin: 4px 0 6px; }
  .band .docbox .rule { height: 1px; background: var(--line); margin-bottom: 6px; }
  .band .docbox .f { display: flex; justify-content: space-between; gap: 10px; margin-bottom: 2px; }
  .band .docbox .k { font-size: 8px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap; }
  .band .docbox .v { font-size: 9px; font-weight: 600; white-space: nowrap; }

  .body-wrap { padding: 16px 38px 26px; }

  .sec-title { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
  .sec-title .t { font-size: 12px; font-weight: 700; }
  .sec-title .c { font-size: 9px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; }

  .items { width: 100%; border-collapse: separate; border-spacing: 0; border: 1px solid var(--line); border-radius: 8px; overflow: hidden; table-layout: fixed; }
  .items thead th { font-size: 8.5px; text-transform: uppercase; letter-spacing: 0.04em; color: #fff; font-weight: 600; background: var(--ink); text-align: left; padding: 9px 10px; }
  .items tbody td { padding: 8px 10px; border-top: 1px solid var(--line); vertical-align: top; font-size: 9.5px; }
  .items tbody tr:first-child td { border-top: 0; }
  .items tbody tr:nth-child(even) td { background: #f8fafd; }
  .items .c-fecha { width: 70px; white-space: nowrap; }
  .items .c-serie { width: 96px; }
  .items .c-taquito { width: 104px; white-space: nowrap; }
  .items .c-placa { width: 70px; white-space: nowrap; }
  .items .c-bul, .items .c-weight, .items .c-flete { text-align: right; }
  .items .c-bul { width: 52px; font-weight: 600; }
  .items .c-weight { width: 78px; }
  .items .c-flete { width: 84px; font-weight: 600; }
  .items .c-pago { width: 100px; }
  .items .party { font-weight: 500; word-break: break-word; }
  .items .pago .pill { display: inline-block; font-size: 8px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; padding: 2px 8px; border-radius: 999px; white-space: nowrap; }
  .items .pago .pill.cancelado { background: var(--accent); color: #fff; }
  .items .pago .pill.cobrar { background: var(--accent-soft); color: var(--accent); }
  .items .pago .pill.pce { border: 1px solid var(--line); color: var(--ink-2); }
  .items tfoot td { padding: 9px 10px; background: var(--accent-soft); border-top: 2px solid var(--accent); font-weight: 700; font-size: 9.5px; }
  .items tfoot .lbl { color: var(--accent); text-transform: uppercase; letter-spacing: 0.04em; font-size: 9px; }
  .items tfoot .c-bul, .items tfoot .c-weight, .items tfoot .c-flete { text-align: right; }
  .items tfoot .c-flete { padding-left: 6px; }

  .foot { margin-top: 18px; padding-top: 12px; border-top: 2px solid var(--ink); }
  .foot .note { font-size: 9px; color: var(--ink-2); }
  .foot .note strong { color: var(--ink); }
  .foot .note .badge { display: inline-block; background: var(--accent-soft); color: var(--accent); padding: 4px 11px; border-radius: 999px; font-size: 8.5px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px; white-space: nowrap; }
</style>
</head>
<body>

<div class="band">
  <div class="logo-block">
    <div class="logo">{% if params.logo is not empty %}<img src="{{ params.logo }}" alt="logo"/>{% else %}<svg viewBox="0 0 40 40" fill="none" stroke="#fff" stroke-width="2.4"><circle cx="20" cy="20" r="14"/><path d="M9 23l5-9 6 4 6-7"/></svg>{% endif %}</div>
    <div>
      <div class="co-name">{{ doc.emisorRazonSocial }}</div>
      <div class="co-sub">{% if doc.emisorDireccion is not empty %}{{ doc.emisorDireccion }} · {% endif %}{% if doc.emisorUbicacion is not empty %}{{ doc.emisorUbicacion }} · {% endif %}RUC {{ doc.emisorRuc }}{% if doc.emisorRegistroMtc is not empty %} · Reg. MTC {{ doc.emisorRegistroMtc }}{% endif %}{% if doc.emisorTelefono is not empty %} · {{ doc.emisorTelefono }}{% endif %}</div>
    </div>
  </div>
  <div class="docbox">
    <div class="kind">MANIFIESTO DE CARGA</div>
    <div class="sub">Documento interno de control</div>
    <div class="num">{{ doc.numero }}</div>
    <div class="rule"></div>
    <div class="f"><span class="k">Fecha de salida</span><span class="v">{% if doc.fechaSalida is not null %}{{ doc.fechaSalida|date('d/m/Y') }}{% endif %}</span></div>
    {% if doc.serie is not empty %}<div class="f"><span class="k">Serie · N°</span><span class="v">{{ doc.serie }} · {{ doc.numero }}</span></div>{% endif %}
    <div class="f"><span class="k">Guías · bultos</span><span class="v">{{ doc.totalGuias }} · {{ doc.totalBultos }}</span></div>
    <div class="f"><span class="k">Peso · flete</span><span class="v">{{ doc.totalPeso|n_format }} kg · S/ {{ doc.totalFlete|n_format }}</span></div>
  </div>
</div>

<div class="body-wrap">

<div class="sec-title"><span class="t">Carga consolidada — guías de remisión</span><span class="c">{{ doc.totalGuias }} guías</span></div>
<table class="items">
  <thead>
    <tr>
      <th class="c-fecha">F. Emisión</th>
      <th class="c-serie">Serie · N°</th>
      <th class="c-taquito">N° Tracking</th>
      <th>Remitente</th>
      <th>Destino</th>
      <th class="c-placa">Placa</th>
      <th class="c-weight">Peso kg</th>
      <th class="c-bul">Bultos</th>
      <th class="c-flete">Flete S/</th>
      <th class="c-pago">Pago</th>
    </tr>
  </thead>
  <tbody>
    {% for l in doc.lineas %}
    <tr>
      <td class="c-fecha mono">{% if l.fechaEmision is not null %}{{ l.fechaEmision|date('d/m/Y') }}{% endif %}</td>
      <td class="c-serie mono">{{ l.guiaSerieNumero }}</td>
      <td class="c-taquito mono">{{ l.taquito }}</td>
      <td class="party">{{ l.remitente }}</td>
      <td class="party">{{ l.destinoDistrito }}</td>
      <td class="c-placa mono">{{ l.placa }}</td>
      <td class="c-weight mono">{{ l.peso|n_format }}</td>
      <td class="c-bul mono">{{ l.bultos }}</td>
      <td class="c-flete mono">{{ l.flete|n_format }}</td>
      <td class="pago">{% if l.condicionPago is not empty %}<span class="pill {{ l.pagoClase }}">{{ l.condicionPago }}</span>{% endif %}</td>
    </tr>
    {% endfor %}
  </tbody>
  <tfoot>
    <tr>
      <td class="lbl" colspan="6">Total · {{ doc.totalGuias }} guías consolidadas</td>
      <td class="c-weight mono">{{ doc.totalPeso|n_format }}</td>
      <td class="c-bul mono">{{ doc.totalBultos }}</td>
      <td class="c-flete mono">{{ doc.totalFlete|n_format }}</td>
      <td class="c-pago"></td>
    </tr>
  </tfoot>
</table>

<div class="foot">
  <div class="note">
    <span class="badge">● Uso interno</span>
    <p>Documento de <strong>control de carga consolidada</strong> para el viaje. No constituye comprobante de pago ni guía de remisión electrónica; cada guía se sustenta de forma individual.</p>
  </div>
</div>

</div>
</body>
</html>
