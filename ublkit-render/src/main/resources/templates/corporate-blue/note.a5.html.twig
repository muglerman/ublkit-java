<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.emisor %}
{% set cl = doc.receptor %}
{% set mon = doc.moneda|catalog('021') %}
{% set sym = doc.moneda|catalogAttr('021','simbolo') %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root {
    --ink: #0b1f3a;
    --ink-2: #334a6b;
    --ink-3: #6b7e96;
    --accent: #1e4694;
    --accent-soft: #eef3fb;
    --line: #d6dde8;
    --rule: #0b1f3a;
  }
  body {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    line-height: 1.45;
    color: var(--ink);
    background: #fff;
    width: 794px;
    min-height: 559px;
    padding: 0;
  }
  .mono { font-family: 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
  p, h1, h2, h3, h4 { margin: 0; }

  .band { background: var(--accent); color: #fff; padding: 22px 36px 24px; display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: center; }
  .band .logo-block { display: flex; align-items: center; gap: 14px; }
  .band .logo { width: 52px; height: 52px; background: rgba(255,255,255,.14); border-radius: 10px; display: flex; align-items: center; justify-content: center; }
  .band .logo svg { width: 32px; height: 32px; }
  .band .logo img { width: 100%; height: 100%; object-fit: contain; border-radius: 10px; }
  .band .co-name { font-size: 16px; font-weight: 700; letter-spacing: 0.01em; }
  .band .co-sub { font-size: 9px; opacity: 0.8; margin-top: 2px; }
  .band .docbox { background: #fff; color: var(--ink); border-radius: 10px; padding: 14px 18px; min-width: 250px; text-align: right; box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .band .docbox .ruc { font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.14em; }
  .band .docbox .ruc b { color: var(--ink); }
  .band .docbox .kind { font-size: 13px; font-weight: 700; color: var(--accent); margin-top: 4px; letter-spacing: 0.04em; }
  .band .docbox .num { font-family: 'IBM Plex Mono', monospace; font-size: 22px; font-weight: 600; margin-top: 2px; }

  .sub-band { padding: 10px 36px; background: #f4f7fc; border-bottom: 1px solid var(--line); display: grid; grid-template-columns: repeat(4, 1fr); font-size: 10px; gap: 16px; }
  .sub-band .k { display: block; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; font-size: 9px; margin-bottom: 2px; }
  .sub-band .v { font-weight: 600; }

  .body-wrap { padding: 22px 36px 28px; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 18px; }
  .party { border: 1px solid var(--line); border-radius: 8px; padding: 14px 16px; }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 600; margin-bottom: 6px; }
  .party .name { font-size: 12.5px; font-weight: 600; margin-bottom: 6px; }
  .party .row { display: grid; grid-template-columns: 80px 1fr; font-size: 10px; padding: 1px 0; }
  .party .row .k { color: var(--ink-3); }

  .items { width: 100%; border-collapse: separate; border-spacing: 0; margin: 0; border-radius: 8px; overflow: hidden; border: 1px solid var(--line); }
  .items thead th { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.08em; color: #fff; font-weight: 600; background: var(--ink); text-align: left; padding: 10px 10px; }
  .items tbody td { padding: 10px; border-top: 1px solid var(--line); vertical-align: top; font-size: 9px; }
  .items tbody tr:first-child td { border-top: 0; }
  .items tbody tr:nth-child(even) td { background: #f8fafd; }
  .items .c-idx { width: 28px; color: var(--ink-3); text-align: center; }
  .items .c-code { width: 90px; }
  .items .c-qty, .items .c-price, .items .c-tax { text-align: right; }
  .items .c-qty { width: 60px; }
  .items .c-unit { width: 50px; text-align: center; color: var(--ink-3); }
  .items .c-price { width: 84px; }
  .items .c-tax { width: 88px; }
  .items .desc .main { font-weight: 500; }
  .items .desc .sub { font-size: 9.5px; color: var(--ink-3); margin-top: 2px; }

  .bottom { display: grid; grid-template-columns: 1fr 310px; gap: 20px; margin-top: 18px; }
  .notes .block { border: 1px solid var(--line); border-radius: 8px; padding: 10px 12px; margin-bottom: 10px; }
  .notes .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 600; margin-bottom: 4px; }
  .notes .block .body { font-size: 10px; }
  .notes .block .body p + p { margin-top: 2px; }
  .notes .small { font-size: 9.5px; color: var(--ink-2); }

  .totals { background: #f4f7fc; border: 1px solid var(--line); border-radius: 8px; padding: 14px 16px; }
  .totals .line { display: flex; justify-content: space-between; padding: 3px 0; font-size: 9px; }
  .totals .line .k { color: var(--ink-2); }
  .totals .line .v { font-family: 'IBM Plex Mono', monospace; white-space: nowrap; }
  .totals .rule { border-top: 1px solid var(--line); margin: 4px 0; }
  .totals .grand { display: flex; justify-content: space-between; padding: 10px 12px; margin: 8px -16px -14px; background: var(--ink); color: #fff; border-radius: 0 0 7px 7px; font-size: 15px; font-weight: 700; }
  .totals .grand .v { font-family: 'IBM Plex Mono', monospace; white-space: nowrap; }
  .totals .in-words { margin-top: 10px; font-size: 9.5px; color: var(--ink-2); font-style: italic; }

  .foot { display: grid; grid-template-columns: 100px 1fr auto; gap: 18px; align-items: start; margin-top: 20px; padding-top: 14px; border-top: 2px solid var(--ink); }
  .foot .qr { width: 100px; height: 100px; background: #fff; padding: 4px; border: 1px solid var(--line); border-radius: 6px; }
  .foot .qr img { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: var(--ink-2); }
  .foot .meta strong { color: var(--ink); }
  .foot .meta .hash { font-family: 'IBM Plex Mono', monospace; word-break: break-all; font-size: 8.5px; margin-top: 2px; }
  .foot .stamp { text-align: right; min-width: 180px; }
  .foot .stamp .badge { display: inline-block; background: var(--accent-soft); color: var(--accent); padding: 5px 12px; border-radius: 999px; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; }
  .foot .stamp .line { font-size: 9.5px; color: var(--ink-2); margin-top: 8px; max-width: 180px; }
</style>
</head>
<body>

<div class="band">
  <div class="logo-block">
    <div class="logo">
      {% if params.logo is not empty %}<img src="{{ params.logo }}" alt="logo"/>{% else %}<svg viewBox="0 0 40 40" fill="none" stroke="#fff" stroke-width="2.4">
        <rect x="6" y="6" width="28" height="28" rx="3"/>
        <path d="M12 20h16M12 14h10M12 26h14"/>
      </svg>{% endif %}
    </div>
    <div>
      <div class="co-name">{{ doc.emisor.razonSocial }}</div>
      <div class="co-sub">{{ doc.emisor.direccion.direccion }}{% if cp is not null and cp.contacto is not null %} · {{ cp.contacto.email }} · {{ cp.contacto.telefono }}{% endif %}</div>
    </div>
  </div>
  <div class="docbox">
    <div class="ruc">R.U.C. <b class="mono">{{ doc.emisor.ruc }}</b></div>
    <div class="kind">{{ name|upper }} ELECTRÓNICA</div>
    <div class="num">{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }}</div>
  </div>
</div>

<div class="sub-band">
  <div><span class="k">Fecha de emisión</span><span class="v">{{ doc.fechaEmision|date('d/m/Y') }} · {{ doc.fechaEmision|date('H:i:s') }}</span></div>
  <div><span class="k">Doc. afectado</span><span class="v">{{ doc.comprobanteAfectadoSerieNumero }}</span></div>
  <div><span class="k">Moneda</span><span class="v">{{ mon }}{% if doc.tipoCambio is not null %} · T/C {{ doc.tipoCambio.venta }}{% endif %}</span></div>
  <div><span class="k">Motivo</span><span class="v">{{ doc.tipoNota|catalog('09') }}</span></div>
</div>

<div class="body-wrap">

<div class="parties">
  <div class="party">
    <div class="label">Cliente / Adquirente</div>
    <div class="name">{{ doc.receptor.nombre }}</div>
    <div class="row"><span class="k">{{ doc.receptor.tipoDocIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ doc.receptor.numDocIdentidad }}</span></div>
    <div class="row"><span class="k">Dirección</span><span>{{ doc.receptor.direccion.direccion }}</span></div>
    <div class="row"><span class="k">Ubicación</span><span>{% if cl is not null and cl.direccion is not null %}{{ cl.direccion.departamento }} — {{ cl.direccion.provincia }} — {{ cl.direccion.distrito }}{% endif %}</span></div>
  </div>
  <div class="party">
    <div class="label">Documento referente</div>
    <div class="name">{{ doc.comprobanteAfectadoTipo|catalog('01') }} {{ doc.comprobanteAfectadoSerieNumero }}</div>
    <div class="row"><span class="k">Motivo</span><span>{{ doc.tipoNota|catalog('09') }}</span></div>
    <div class="row"><span class="k">Sustento</span><span>{{ doc.sustentoDescripcion }}</span></div>
  </div>
</div>

<table class="items">
  <thead>
    <tr>
      <th class="c-idx">#</th>
      <th class="c-code">Código</th>
      <th>Descripción</th>
      <th class="c-unit">Und</th>
      <th class="c-qty">Cant.</th>
      <th class="c-price">P. Unit.</th>
      <th class="c-tax">Importe</th>
    </tr>
  </thead>
  <tbody>

    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codigoProducto }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div><div class="sub">{% if det.codProductoSUNAT %}SUNAT {{ det.codigoProductoSunat }}{% endif %}</div><div class="sub">{% if det.igvTipo %}{{ det.igvTipo|catalog('07') }}{% endif %}</div></td>
      <td class="c-unit">{{ det.unidadMedida }}</td>
      <td class="c-qty mono">{{ det.cantidad|n_format }}</td>
      <td class="c-price mono">{{ det.precio|n_format }}</td>
      <td class="c-tax mono">{{ (det.precio * det.cantidad)|n_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<div class="bottom">
  <div class="notes">
    {% if doc.observaciones %}
    <div class="block">
      <div class="head">Observaciones</div>
      <div class="body"><p>{{ doc.observaciones }}</p></div>
    </div>
    {% endif %}
    <div class="block">
      <div class="head">Sustento</div>
      <div class="body"><p>{{ doc.sustentoDescripcion }}</p></div>
    </div>
    <div class="block">
      <div class="head">Leyendas SUNAT</div>
      <div class="body">
        {% if doc.leyendas is not empty %}{% for entry in doc.leyendas %}<p class="small">· {{ entry.value }}</p>{% endfor %}{% endif %}
      </div>
    </div>
  </div>

  <div class="totals">
    {% if doc.totalImporte is not null and doc.totalImporte.importeSinImpuestos is not null %}
    <div class="line"><span class="k">Subtotal</span><span class="v">{{ sym }} {{ doc.totalImporte.importeSinImpuestos|n_format }}</span></div>
    {% endif %}
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.gravadoBaseImponible is not null %}
    <div class="line"><span class="k">Op. gravadas</span><span class="v">{{ sym }} {{ doc.totalImpuestos.gravadoBaseImponible|n_format }}</span></div>
    {% endif %}
    <div class="rule"></div>
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.gravadoImporte is not null %}
    <div class="line"><span class="k">IGV (18%)</span><span class="v">{{ sym }} {{ doc.totalImpuestos.gravadoImporte|n_format }}</span></div>
    {% endif %}
    <div class="in-words">{% if doc.leyendas['1000'] %}Son: {{ doc.leyendas['1000'] }}{% endif %}</div>
    <div class="grand"><span>TOTAL NOTA</span><span class="v">{{ sym }} {{ doc.totalImporte.importeConImpuestos|n_format }}</span></div>
  </div>
</div>

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}<img src="data:image/png;base64,{{ qrBase64 }}" alt="QR Code" />{% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la {{ name }}.</p>
    <p>Consulte la validez en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> con el RUC del emisor y el número del documento.</p>
    <p style="margin-top:6px;">Firmante digital: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    <p class="hash">Hash: {{ hashDocumento }}</p>
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">● Nota aceptada SUNAT</span>
    <div class="line">Documento electrónico que modifica el comprobante referenciado.</div>
  </div>
</div>

</div>
</body>
</html>
