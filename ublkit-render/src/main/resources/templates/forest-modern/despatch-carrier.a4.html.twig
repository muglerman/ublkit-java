<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.remitente %}
{% set tercero = doc.tercero %}
{% set cl = doc.destinatario %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root { --ink: #1a2720; --ink-2: #48554e; --ink-3: #7b8882; --accent: #1d6b4f; --accent-2: #d1e7dc; --accent-soft: #f2f8f5; --line: #d9e0dc; --paper: #fdfdfb; }
  body { font-family: 'Space Grotesk', sans-serif; font-size: 10.5px; line-height: 1.5; color: var(--ink); background: var(--paper); width: 794px; min-height: 1123px; padding: 40px 44px; }
  .mono { font-family: 'JetBrains Mono', monospace; font-variant-numeric: tabular-nums; }
  p, h1, h2, h3 { margin: 0; }

  .hero { display: grid; grid-template-columns: 1fr auto; align-items: start; gap: 32px; margin-bottom: 20px; }
  .brand .mark { display: flex; align-items: center; gap: 14px; }
  .brand .logo { width: 56px; height: 56px; color: var(--accent); display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .brand .logo svg { width: 30px; height: 30px; }
  .brand .logo img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; }
  .brand .co-name { font-size: 15px; font-weight: 700; }
  .brand .co-tagline { font-size: 10.5px; color: var(--ink-3); margin-top: 1px; }
  .brand .meta { margin-top: 12px; font-size: 10.5px; color: var(--ink-2); }

  .doc-id { text-align: right; border-left: 3px solid var(--accent); padding-left: 18px; min-width: 240px; }
  .doc-id .tag { font-size: 9.5px; color: var(--accent); font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; }
  .doc-id .kind { font-size: 20px; font-weight: 700; line-height: 1.1; margin-top: 4px; }
  .doc-id .sub { font-size: 11px; color: var(--ink-2); }
  .doc-id .num { font-family: 'JetBrains Mono', monospace; font-size: 18px; font-weight: 500; color: var(--accent); margin-top: 2px; }
  .doc-id .ruc { margin-top: 10px; font-size: 10px; color: var(--ink-2); }
  .doc-id .ruc b { color: var(--ink); font-family: 'JetBrains Mono', monospace; }

  .trip-band { background: var(--accent); color: #fff; border-radius: 14px; padding: 18px 22px; display: grid; grid-template-columns: 1fr auto 1fr; gap: 20px; align-items: center; margin-bottom: 20px; }
  .trip-band .leg .k { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.14em; opacity: 0.75; }
  .trip-band .leg .v { font-size: 13px; font-weight: 700; margin-top: 2px; }
  .trip-band .leg .addr { font-size: 10px; opacity: 0.85; margin-top: 2px; }
  .trip-band .arrow { font-size: 24px; opacity: 0.8; }
  .trip-band .right { text-align: right; }

  .meta-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
  .meta-row .chip { background: var(--accent-soft); border-radius: 10px; padding: 10px 12px; }
  .meta-row .chip .k { font-size: 9px; color: var(--accent); letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; display: block; margin-bottom: 4px; }
  .meta-row .chip .v { font-size: 11px; font-weight: 500; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 18px; }
  .party { background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-3); margin-bottom: 4px; }
  .party .name { font-size: 11.5px; font-weight: 700; margin-bottom: 6px; }
  .party .row { display: grid; grid-template-columns: 78px 1fr; font-size: 10px; padding: 1px 0; }
  .party .row .k { color: var(--ink-3); }

  .section-title { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-3); font-weight: 600; margin: 0 0 10px; }

  .items-wrap { background: #fff; border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
  .items { width: 100%; border-collapse: collapse; }
  .items thead th { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-2); font-weight: 600; text-align: left; padding: 12px; background: var(--accent-soft); border-bottom: 1px solid var(--line); }
  .items tbody td { padding: 11px 12px; border-top: 1px solid var(--line); vertical-align: top; font-size: 10.5px; }
  .items .c-idx { width: 26px; color: var(--ink-3); text-align: center; }
  .items .c-code { width: 90px; }
  .items .c-qty { text-align: right; width: 90px; font-weight: 600; }
  .items .c-unit { width: 50px; text-align: center; color: var(--ink-3); }
  .items .desc .main { font-weight: 500; }
  .items .desc .sub { font-size: 9.5px; color: var(--ink-3); margin-top: 2px; }

  .transport { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 16px; }
  .transport .card { background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; }
  .transport .card .head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .transport .card .head .icon { width: 24px; height: 24px; background: var(--accent-soft); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: var(--accent); }
  .transport .card .head .title { font-size: 11px; font-weight: 700; }
  .transport .card .row { display: grid; grid-template-columns: 82px 1fr; font-size: 10px; padding: 1.5px 0; }
  .transport .card .row .k { color: var(--ink-3); }

  .related { background: var(--accent-soft); border-radius: 12px; padding: 14px 18px; margin-top: 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .related .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 600; margin-bottom: 4px; }
  .related .block .body { font-size: 10px; }
  .related .small { font-size: 9.5px; color: var(--ink-2); }

  .foot { display: grid; grid-template-columns: 100px 1fr auto; gap: 18px; align-items: start; margin-top: 22px; padding-top: 16px; border-top: 1px solid var(--line); }
  .foot .qr { width: 100px; height: 100px; background: #fff; padding: 6px; border-radius: 10px; border: 1px solid var(--line); }
  .foot .qr img { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: var(--ink-2); }
  .foot .meta strong { color: var(--ink); }
  .foot .stamp { text-align: right; min-width: 180px; }
  .foot .stamp .badge { display: inline-flex; align-items: center; gap: 5px; background: var(--accent-2); color: var(--accent); padding: 6px 12px; border-radius: 999px; font-size: 9.5px; font-weight: 600; }
  .foot .stamp .badge::before { content: ""; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }
  .foot .stamp .line { font-size: 9.5px; color: var(--ink-2); margin-top: 8px; max-width: 180px; }
</style>
</head>
<body>

<div class="hero">
  <div class="brand">
    <div class="mark">
      <div class="logo">{% if params.logo is not empty %}<img src="{{ params.logo }}" alt="logo"/>{% else %}<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.4"><circle cx="20" cy="20" r="14"/><path d="M9 23l5-9 6 4 6-7"/></svg>{% endif %}</div>
      <div>
        <div class="co-name">{% if cp is not null %}{{ cp.razonSocial }}{% endif %}</div>
        <div class="co-tagline">{% if cp is not null and cp.nombreComercial is not null and cp.nombreComercial != cp.razonSocial %}{{ cp.nombreComercial }}{% endif %}</div>
      </div>
    </div>
    <div class="meta">
      <p>{% if cp is not null and cp.direccion is not null %}{{ cp.direccion.direccion }}{% endif %}{% if doc.subcontratado is not null %} · Subcontratado: {{ doc.subcontratado.nombre }}{% endif %}</p>
      {% if doc.envio is not null and doc.envio.transportista is not null and doc.envio.transportista.numeroRegistroMTC is not empty %}<p>Reg. MTC {{ doc.envio.transportista.numeroRegistroMTC }}</p>{% endif %}
      <p>{% if cp is not null and cp.contacto is not null %}{% if cp.contacto.email is not empty %}{{ cp.contacto.email }}{% endif %}{% if cp.contacto.email is not empty and cp.contacto.telefono is not empty %} · {% endif %}{{ cp.contacto.telefono }}{% endif %}</p>
    </div>
  </div>
  <div class="doc-id">
    <div class="tag">Servicio de transporte</div>
    <div class="kind">{{ name|upper }} ELECTRÓNICA</div>
    <div class="num">{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }}</div>
    <div class="ruc">RUC <b>{% if cp is not null %}{{ cp.ruc }}{% endif %}</b></div>
  </div>
</div>

<div class="trip-band">
  <div class="leg">
    <div class="k">Partida</div>
    <div class="v">{% if doc.envio is not null and doc.envio.partida is not null %}{{ doc.envio.partida.direccion }}{% endif %}</div>
    <div class="addr">{% if params.partidaDistrito is not empty %}{% if params.partidaDepartamento is not empty %}{{ params.partidaDepartamento }} — {{ params.partidaProvincia }} — {% endif %}{{ params.partidaDistrito }}{% endif %}{% if doc.envio is not null and doc.envio.partida is not null and doc.envio.partida.ubigeo is not empty %} · Ubigeo {{ doc.envio.partida.ubigeo }}{% endif %}</div>
  </div>
  <div class="arrow">→</div>
  <div class="leg right">
    <div class="k">Llegada</div>
    <div class="v">{% if doc.envio is not null and doc.envio.destino is not null %}{{ doc.envio.destino.direccion }}{% endif %}</div>
    <div class="addr">{% if params.destinoDistrito is not empty %}{% if params.destinoDepartamento is not empty %}{{ params.destinoDepartamento }} — {{ params.destinoProvincia }} — {% endif %}{{ params.destinoDistrito }}{% endif %}{% if doc.envio is not null and doc.envio.destino is not null and doc.envio.destino.ubigeo is not empty %} · Ubigeo {{ doc.envio.destino.ubigeo }}{% endif %}</div>
  </div>
</div>

<div class="meta-row">
  <div class="chip"><span class="k">Emisión</span><span class="v">{{ doc.fechaEmision|date('d/m/Y') }}</span></div>
  <div class="chip"><span class="k">Inicio traslado</span><span class="v">{% if doc.envio is not null and doc.envio.fechaTraslado is not null %}{{ doc.envio.fechaTraslado|date('d/m/Y') }}{% endif %}</span></div>
  <div class="chip"><span class="k">Modalidad</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.tipoModalidadTraslado|catalog('18') }}{% endif %}</span></div>
  <div class="chip"><span class="k">Peso · bultos</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.pesoTotal }} {{ doc.envio.pesoTotalUnidadMedida }}{% if doc.envio.numeroDeBultos is not null %} · {{ doc.envio.numeroDeBultos }}{% endif %}{% endif %}</span></div>
  <div class="chip"><span class="k">Estado de pago</span><span class="v">{% if params.estadoPago is not empty %}{{ params.estadoPago }}{% endif %}</span></div><div class="chip"><span class="k">Nro. taquito</span><span class="v">{% if params.trackingNumber is not empty %}{{ params.trackingNumber }}{% endif %}</span></div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Remitente</div>
    {% if tercero is not null %}
    <div class="name">{{ tercero.nombre }}</div>
    <div class="row"><span class="k">{{ tercero.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ tercero.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
  </div>
  <div class="party">
    <div class="label">Destinatario</div>
    {% if cl is not null %}
    <div class="name">{{ cl.nombre }}</div>
    <div class="row"><span class="k">{{ cl.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ cl.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
  </div>
</div>

<p class="section-title">Bienes transportados</p>
<div class="items-wrap">
<table class="items">
  <thead>
    <tr><th class="c-idx">#</th><th class="c-code">Código</th><th>Descripción</th><th class="c-unit">Und</th><th class="c-qty">Cant.</th></tr>
  </thead>
  <tbody>
    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codigo }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div></td>
      <td class="c-unit">{{ det.unidadMedida }}</td>
      <td class="c-qty mono">{{ det.cantidad|q_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
  {% if params.totalGuia is not empty and params.totalGuia > 0 %}<tfoot><tr><td colspan="99" style="text-align:right;padding:10px 12px;font-weight:700;">Monto total: S/ {{ params.totalGuia|n_format }}</td></tr></tfoot>{% endif %}
</table>
</div>

<div class="transport">
  <div class="card">
    <div class="head"><div class="icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 17V7h13l5 5v5M3 17h2M9 17h10M5 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm14 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></svg></div><div class="title">Vehículos</div></div>
    {% if doc.envio is not null and doc.envio.vehiculo is not null %}
    <div class="row"><span class="k">Placa principal</span><span class="mono">{{ doc.envio.vehiculo.placa }}</span></div>
    {% if doc.envio.vehiculo.numeroCirculacion is not empty %}
    <div class="row"><span class="k">TUC/CHV</span><span class="mono">{{ doc.envio.vehiculo.numeroCirculacion }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.marca is not empty %}
    <div class="row"><span class="k">Marca</span><span>{{ doc.envio.vehiculo.marca }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.modelo is not empty %}
    <div class="row"><span class="k">Modelo</span><span>{{ doc.envio.vehiculo.modelo }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.numeroAutorizacion is not empty %}
    <div class="row"><span class="k">Autorización</span><span class="mono">{{ doc.envio.vehiculo.numeroAutorizacion }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.secundarios is not empty %}{% for v in doc.envio.vehiculo.secundarios %}<div class="row"><span class="k">Placa secundaria</span><span class="mono">{{ v.placa }}{% if v.numeroCirculacion is not empty %} · TUC {{ v.numeroCirculacion }}{% endif %}</span></div>{% endfor %}{% endif %}
    {% endif %}
  </div>
  <div class="card">
    <div class="head"><div class="icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg></div><div class="title">Conductores</div></div>
    {% if doc.envio is not null and doc.envio.choferes is not empty %}{% for ch in doc.envio.choferes %}
    <div class="row"><span class="k">{% if loop.first %}Principal{% else %}Secundario{% endif %}</span><span>{{ ch.nombres }} {{ ch.apellidos }}</span></div>
    <div class="row"><span class="k">{{ ch.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }} · Brevete</span><span class="mono">{{ ch.numeroDocumentoIdentidad }}{% if ch.licencia is not empty %} · {{ ch.licencia }}{% endif %}</span></div>
    {% endfor %}{% endif %}
  </div>
</div>

{% if doc.documentosRelacionados is not empty or doc.observaciones is not empty %}
<div class="related">
  {% if doc.documentosRelacionados is not empty %}
  <div class="block">
    <div class="head">Documentos relacionados</div>
    <div class="body">
      {% for rel in doc.documentosRelacionados %}
      <p>{{ rel.tipoDocumento }} · <span class="mono">{{ rel.serieNumero }}</span></p>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  {% if doc.observaciones is not empty %}
  <div class="block">
    <div class="head">Observaciones</div>
    <div class="body">
      {% for obs in doc.observaciones|split('\n') %}<p class="small">· {{ obs }}</p>{% endfor %}
    </div>
  </div>
  {% endif %}
</div>
{% endif %}

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}<img src="data:image/png;base64,{{ qrBase64 }}" alt="QR Code" />{% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la Guía de Remisión Transportista Electrónica.</p>
    <p>Consulte la validez en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> con el RUC del transportista y el número del documento.</p>
    <p style="margin-top:6px;">Firmante: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">GRE-T autorizada</span>
    <div class="line">Emitido conforme a la RS SUNAT 271-2019.</div>
  </div>
</div>

</body>
</html>
