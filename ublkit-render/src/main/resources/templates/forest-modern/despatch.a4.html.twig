<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.remitente %}
{% set cl = doc.destinatario %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root { --ink: #1a2720; --ink-2: #48554e; --ink-3: #7b8882; --accent: #1d6b4f; --accent-2: #d1e7dc; --accent-soft: #f2f8f5; --line: #d9e0dc; --paper: #fdfdfb; }
  body { font-family: 'Space Grotesk', sans-serif; font-size: 10.5px; line-height: 1.5; color: var(--ink); background: var(--paper); width: 794px; min-height: 1123px; padding: 40px 44px; }
  .mono { font-family: 'JetBrains Mono', monospace; font-variant-numeric: tabular-nums; }
  p, h1, h2, h3 { margin: 0; }

  .hero { display: grid; grid-template-columns: 1fr auto; align-items: start; gap: 32px; margin-bottom: 20px; }
  .brand .mark { display: flex; align-items: center; gap: 14px; }
  .brand .logo { width: 50px; height: 50px; background: var(--accent); color: #fff; border-radius: 14px; display: flex; align-items: center; justify-content: center; }
  .brand .logo svg { width: 32px; height: 32px; }
  .brand .logo img { width: 100%; height: 100%; object-fit: contain; border-radius: 14px; }
  .brand .co-name { font-size: 16px; font-weight: 700; }
  .brand .co-tagline { font-size: 10.5px; color: var(--ink-3); margin-top: 1px; }
  .brand .meta { margin-top: 12px; font-size: 10.5px; color: var(--ink-2); }

  .doc-id { text-align: right; border-left: 3px solid var(--accent); padding-left: 18px; min-width: 240px; }
  .doc-id .tag { font-size: 9.5px; color: var(--accent); font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; }
  .doc-id .kind { font-size: 22px; font-weight: 700; line-height: 1.1; margin-top: 4px; }
  .doc-id .sub { font-size: 11px; color: var(--ink-2); }
  .doc-id .num { font-family: 'JetBrains Mono', monospace; font-size: 18px; font-weight: 500; color: var(--accent); margin-top: 2px; }
  .doc-id .ruc { margin-top: 10px; font-size: 10px; color: var(--ink-2); }
  .doc-id .ruc b { color: var(--ink); font-family: 'JetBrains Mono', monospace; }

  .trip-band { background: var(--accent); color: #fff; border-radius: 14px; padding: 18px 22px; display: grid; grid-template-columns: 1fr auto 1fr; gap: 20px; align-items: center; margin-bottom: 20px; }
  .trip-band .leg .k { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.14em; opacity: 0.75; }
  .trip-band .leg .v { font-size: 13px; font-weight: 700; margin-top: 2px; }
  .trip-band .leg .addr { font-size: 10px; opacity: 0.85; margin-top: 2px; }
  .trip-band .arrow { font-size: 24px; opacity: 0.8; }
  .trip-band .right { text-align: right; }

  .meta-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
  .meta-row .chip { background: var(--accent-soft); border-radius: 10px; padding: 10px 12px; }
  .meta-row .chip .k { font-size: 9px; color: var(--accent); letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; display: block; margin-bottom: 4px; }
  .meta-row .chip .v { font-size: 11px; font-weight: 500; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 18px; }
  .party { background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-3); margin-bottom: 4px; }
  .party .name { font-size: 13px; font-weight: 700; margin-bottom: 6px; }
  .party .row { display: grid; grid-template-columns: 78px 1fr; font-size: 10px; padding: 1px 0; }
  .party .row .k { color: var(--ink-3); }

  .section-title { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-3); font-weight: 600; margin: 0 0 10px; }

  .items-wrap { background: #fff; border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
  .items { width: 100%; border-collapse: collapse; }
  .items thead th { font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-2); font-weight: 600; text-align: left; padding: 12px; background: var(--accent-soft); border-bottom: 1px solid var(--line); }
  .items tbody td { padding: 11px 12px; border-top: 1px solid var(--line); vertical-align: top; font-size: 10.5px; }
  .items .c-idx { width: 26px; color: var(--ink-3); text-align: center; }
  .items .c-code { width: 90px; }
  .items .c-qty { text-align: right; width: 90px; font-weight: 600; }
  .items .c-unit { width: 50px; text-align: center; color: var(--ink-3); }
  .items .c-weight { width: 90px; text-align: right; color: var(--ink-2); }
  .items .desc .main { font-weight: 500; }
  .items .desc .sub { font-size: 9.5px; color: var(--ink-3); margin-top: 2px; }

  .transport { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 16px; }
  .transport .card { background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; }
  .transport .card .head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .transport .card .head .icon { width: 24px; height: 24px; background: var(--accent-soft); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: var(--accent); }
  .transport .card .head .title { font-size: 11px; font-weight: 700; }
  .transport .card .row { display: grid; grid-template-columns: 82px 1fr; font-size: 10px; padding: 1.5px 0; }
  .transport .card .row .k { color: var(--ink-3); }

  .sign-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 20px; }
  .sign-box { border-top: 1px solid var(--ink); padding-top: 6px; text-align: center; font-size: 10px; color: var(--ink-2); min-height: 68px; }
  .sign-box .role { font-weight: 600; color: var(--ink); font-size: 10.5px; }
  .sign-box .meta { font-size: 9px; color: var(--ink-3); margin-top: 2px; }

  .foot { display: grid; grid-template-columns: 100px 1fr auto; gap: 18px; align-items: start; margin-top: 22px; padding-top: 16px; border-top: 1px solid var(--line); }
  .foot .qr { width: 100px; height: 100px; background: #fff; padding: 6px; border-radius: 10px; border: 1px solid var(--line); }
  .foot .qr img { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: var(--ink-2); }
  .foot .meta strong { color: var(--ink); }
  .foot .stamp { text-align: right; min-width: 180px; }
  .foot .stamp .badge { display: inline-flex; align-items: center; gap: 5px; background: var(--accent-2); color: var(--accent); padding: 6px 12px; border-radius: 999px; font-size: 9.5px; font-weight: 600; }
  .foot .stamp .badge::before { content: ""; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }
  .foot .stamp .line { font-size: 9.5px; color: var(--ink-2); margin-top: 8px; max-width: 180px; }
</style>
</head>
<body>

<div class="hero">
  <div class="brand">
    <div class="mark">
      <div class="logo">{% if params.logo is not empty %}<img src="{{ params.logo }}" alt="logo"/>{% else %}<svg viewBox="0 0 40 40" fill="none" stroke="#fff" stroke-width="2.4"><rect x="6" y="6" width="28" height="28" rx="3"/><path d="M12 20h16M12 14h10M12 26h14"/></svg>{% endif %}</div>
      <div>
        <div class="co-name">{% if cp is not null %}{{ cp.razonSocial }}{% endif %}</div>
        <div class="co-tagline">{% if cp is not null and cp.nombreComercial is not null and cp.nombreComercial != cp.razonSocial %}{{ cp.nombreComercial }}{% endif %}</div>
      </div>
    </div>
    <div class="meta">
      <p>{% if cp is not null and cp.direccion is not null %}{{ cp.direccion.direccion }}{% endif %}</p>
      <p>{% if cp is not null and cp.contacto is not null %}{{ cp.contacto.email }} · {{ cp.contacto.telefono }}{% endif %}</p>
    </div>
  </div>
  <div class="doc-id">
    <div class="tag">Traslado de bienes</div>
    <div class="kind">{% if doc.tipoComprobante is not empty %}{{ name|upper }} ELECTRÓNICA{% else %}Guía de Remisión{% endif %}</div>
    <div class="num">{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }}</div>
    <div class="ruc">RUC <b>{% if cp is not null %}{{ cp.ruc }}{% endif %}</b></div>
  </div>
</div>

<div class="trip-band">
  <div class="leg">
    <div class="k">Partida</div>
    <div class="v">{% if doc.envio is not null and doc.envio.partida is not null %}{{ doc.envio.partida.direccion }}{% endif %}</div>
    <div class="addr">{% if doc.envio is not null and doc.envio.partida is not null %}{{ doc.envio.partida.ubigeo }}{% endif %}</div>
  </div>
  <div class="arrow">→</div>
  <div class="leg right">
    <div class="k">Llegada</div>
    <div class="v">{% if doc.envio is not null and doc.envio.destino is not null %}{{ doc.envio.destino.direccion }}{% endif %}</div>
    <div class="addr">{% if doc.envio is not null and doc.envio.destino is not null %}{{ doc.envio.destino.ubigeo }}{% endif %}</div>
  </div>
</div>

<div class="meta-row">
  <div class="chip"><span class="k">Fecha emisión</span><span class="v">{{ doc.fechaEmision|date('d/m/Y') }}</span></div>
  <div class="chip"><span class="k">Inicio traslado</span><span class="v">{% if doc.envio is not null and doc.envio.fechaTraslado is not null %}{{ doc.envio.fechaTraslado|date('d/m/Y') }}{% endif %}</span></div>
  <div class="chip"><span class="k">Motivo</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.tipoTraslado|catalog('20') }}{% endif %}</span></div>
  <div class="chip"><span class="k">Modalidad</span><span class="v">{% if doc.envio is not null %}{{ doc.envio.tipoModalidadTraslado|catalog('18') }}{% endif %}</span></div>
  <div class="chip"><span class="k">Estado de pago</span><span class="v">{% if params.estadoPago is not empty %}{{ params.estadoPago }}{% endif %}</span></div><div class="chip"><span class="k">Nro. taquito</span><span class="v">{% if params.trackingNumber is not empty %}{{ params.trackingNumber }}{% endif %}</span></div><div class="chip"><span class="k">Total</span><span class="v">{% if params.totalGuia is not empty %}{{ params.totalGuia|n_format }}{% endif %}</span></div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Destinatario</div>
    <div class="name">{% if cl is not null %}{{ cl.nombre }}{% endif %}</div>
    <div class="row"><span class="k">{% if cl is not null %}{{ cl.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}{% endif %}</span><span class="mono">{% if cl is not null %}{{ cl.numeroDocumentoIdentidad }}{% endif %}</span></div>
    {% if doc.envio is not null %}
    <div class="row"><span class="k">Bultos</span><span>{{ doc.envio.numeroDeBultos }}</span></div>
    <div class="row"><span class="k">Peso total</span><span>{{ doc.envio.pesoTotal }} {{ doc.envio.pesoTotalUnidadMedida }}</span></div>
    {% endif %}
  </div>
  <div class="party">
    <div class="label">Transporte</div>
    {% if doc.envio is not null and doc.envio.transportista is not null %}
    <div class="name">{{ doc.envio.transportista.nombre }}</div>
    <div class="row"><span class="k">RUC transp.</span><span class="mono">{{ doc.envio.transportista.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
    {% if doc.envio is not null and doc.envio.vehiculo is not null %}
    <div class="row"><span class="k">Vehículo</span><span class="mono">{{ doc.envio.vehiculo.placa }}</span></div>
    {% endif %}
    {% if doc.envio is not null and doc.envio.choferes is not empty %}
    <div class="row"><span class="k">Conductor</span><span>{{ doc.envio.choferes[0].nombres }} {{ doc.envio.choferes[0].apellidos }}</span></div>
    {% endif %}
  </div>
</div>

<p class="section-title">Bienes trasladados</p>
<div class="items-wrap">
<table class="items">
  <thead>
    <tr><th class="c-idx">#</th>
      <th class="c-code">Código</th>
      <th>Descripción</th>
      <th class="c-unit">Und</th>
      <th class="c-qty">Cant.</th></tr>
  </thead>
  <tbody>

    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codigo }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div></td>
      <td class="c-unit">{{ det.unidadMedida }}</td>
      <td class="c-qty mono">{{ det.cantidad|n_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
  {% if params.totalGuia is not empty and params.totalGuia > 0 %}<tfoot><tr><td colspan="99" style="text-align:right;padding:10px 12px;font-weight:700;">Monto total: S/ {{ params.totalGuia|n_format }}</td></tr></tfoot>{% endif %}
</table>
</div>

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}<img src="data:image/png;base64,{{ qrBase64 }}" alt="QR Code" />{% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la {% if doc.tipoComprobante is not empty %}{{ name|upper }} ELECTRÓNICA{% else %}Guía de Remisión{% endif %} Electrónica.</p>
    <p>Consulte la validez en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> con el RUC del remitente y el número del documento.</p>
    <p style="margin-top:6px;">Firmante: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">GRE autorizada</span>
    <div class="line">Documento electrónico emitido conforme a la RS SUNAT 271-2019.</div>
  </div>
</div>

</body>
</html>
