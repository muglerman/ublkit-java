<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.remitente %}
{% set cl = doc.destinatario %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root { --ink: #161411; --ink-2: #57524b; --ink-3: #8c857c; --paper: #fbfaf6; --rule: #161411; --line: #e6e2d9; --accent: #2f5a4a; }
  body { font-family: 'Inter', sans-serif; font-size: 10.5px; line-height: 1.5; color: var(--ink); background: var(--paper); width: 794px; min-height: 1123px; padding: 48px 56px; }
  .mono { font-family: 'JetBrains Mono', monospace; font-variant-numeric: tabular-nums; }
  .serif { font-family: 'Newsreader', serif; }
  p { margin: 0; }

  .hero { text-align: center; padding-bottom: 20px; border-bottom: 1px solid var(--rule); }
  .hero .co-name { font-family: 'Newsreader', serif; font-size: 21px; font-weight: 500; letter-spacing: 0.01em; }
  .hero .co-sub { font-size: 10px; color: var(--ink-2); margin-top: 3px; letter-spacing: 0.03em; }
  .hero .doc-kind { margin-top: 16px; font-family: 'Newsreader', serif; font-style: italic; font-size: 14px; color: var(--ink-2); }
  .hero .doc-sub { font-size: 9.5px; color: var(--ink-3); letter-spacing: 0.12em; text-transform: uppercase; margin-top: 2px; }
  .hero .doc-num { margin-top: 4px; font-family: 'JetBrains Mono', monospace; font-size: 22px; font-weight: 500; letter-spacing: 0.03em; }

  .route { display: grid; grid-template-columns: 1fr auto 1fr; gap: 24px; align-items: center; padding: 20px 0; border-bottom: 1px solid var(--line); }
  .route .leg .k { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--ink-3); margin-bottom: 3px; }
  .route .leg .v { font-family: 'Newsreader', serif; font-size: 14px; font-weight: 500; }
  .route .leg .a { font-size: 10px; color: var(--ink-2); margin-top: 1px; }
  .route .arrow { font-family: 'Newsreader', serif; font-style: italic; color: var(--accent); font-size: 18px; }
  .route .leg.right { text-align: right; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; padding: 20px 0; border-bottom: 1px solid var(--line); }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--ink-3); margin-bottom: 6px; }
  .party .name { font-family: 'Newsreader', serif; font-size: 13px; font-weight: 500; margin-bottom: 6px; }
  .party .row { display: grid; grid-template-columns: 72px 1fr; font-size: 10px; padding: 1px 0; }
  .party .row .k { color: var(--ink-3); }

  .meta-grid { display: grid; grid-template-columns: repeat(4, 1fr); padding: 18px 0; border-bottom: 1px solid var(--line); }
  .meta-grid > div { padding: 0 14px; }
  .meta-grid > div + div { border-left: 1px solid var(--line); }
  .meta-grid .k { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--ink-3); margin-bottom: 3px; }
  .meta-grid .v { font-size: 11px; font-weight: 500; }

  .section { padding-top: 20px; }
  .section-title { font-family: 'Newsreader', serif; font-style: italic; font-size: 13px; color: var(--ink-2); margin-bottom: 10px; }

  .items { width: 100%; border-collapse: collapse; }
  .items thead th { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-3); font-weight: 500; text-align: left; padding: 8px 10px 8px 0; border-bottom: 1px solid var(--rule); }
  .items tbody td { padding: 12px 10px 12px 0; border-bottom: 1px solid var(--line); vertical-align: top; font-size: 10.5px; }
  .items .c-idx { width: 28px; color: var(--ink-3); }
  .items .c-code { width: 86px; }
  .items .c-qty, .items .c-unit { text-align: right; }
  .items .c-unit { width: 50px; text-align: center; color: var(--ink-3); }
  .items .c-qty { width: 70px; padding-right: 0; }
  .items .desc .main { font-weight: 500; }
  .items .desc .sub { font-size: 9.5px; color: var(--ink-3); margin-top: 2px; }

  .twocol { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; padding-top: 22px; }
  .twocol .block .head { font-family: 'Newsreader', serif; font-style: italic; font-size: 13px; color: var(--ink-2); margin-bottom: 8px; }
  .twocol .block .row { display: grid; grid-template-columns: 90px 1fr; font-size: 10px; padding: 2px 0; }
  .twocol .block .row .k { color: var(--ink-3); }

  .related { padding: 20px 0 0; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
  .related .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--ink-3); margin-bottom: 4px; }
  .related .block .body { font-size: 10px; }
  .related .small { font-size: 9.5px; color: var(--ink-2); }

  .signs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 44px; }
  .signs .box { border-top: 1px solid var(--rule); padding-top: 6px; text-align: center; font-size: 10px; }
  .signs .box .role { font-family: 'Newsreader', serif; font-style: italic; font-size: 12px; }
  .signs .box .meta { font-size: 9px; color: var(--ink-3); margin-top: 2px; }

  .foot { display: grid; grid-template-columns: 90px 1fr auto; gap: 22px; align-items: start; margin-top: 30px; padding-top: 18px; border-top: 1px solid var(--line); }
  .foot .qr { width: 90px; height: 90px; background: #fff; padding: 4px; border: 1px solid var(--line); }
  .foot .qr img { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: var(--ink-2); }
  .foot .meta strong { color: var(--ink); }
  .foot .meta .hash { font-family: 'JetBrains Mono', monospace; word-break: break-all; font-size: 8.5px; margin-top: 2px; color: var(--ink-3); }
  .foot .stamp { text-align: right; min-width: 180px; }
  .foot .stamp .badge { display: inline-block; color: var(--accent); padding: 4px 0; font-family: 'Newsreader', serif; font-style: italic; font-size: 13px; border-bottom: 1px solid var(--accent); }
  .foot .stamp .line { font-size: 9.5px; color: var(--ink-2); margin-top: 8px; max-width: 180px; }
</style>
</head>
<body>

<div class="hero">
  <div class="co-name">{% if cp is not null %}{{ cp.razonSocial }}{% endif %}</div>
  <div class="co-sub">{% if cp is not null and cp.direccion is not null %}{{ cp.direccion.direccion }} · {% endif %}{% if cp is not null %}RUC {{ cp.ruc }}{% endif %}{% if cp is not null and cp.contacto is not null %} · {{ cp.contacto.email }}{% endif %}</div>
  <div class="doc-kind">{{ name|upper }} ELECTRÓNICA</div>
  <div class="doc-num">{{ doc.serie }} · {{ doc.numero|str_pad(8, '0', 'left') }}</div>
</div>

<div class="route">
  <div class="leg">
    <div class="k">Partida</div>
    <div class="v">{% if doc.envio is not null and doc.envio.partida is not null %}{{ doc.envio.partida.direccion }}{% endif %}</div>
    <div class="a">{% if params.partidaDistrito is not empty %}{% if params.partidaDepartamento is not empty %}{{ params.partidaDepartamento }} — {{ params.partidaProvincia }} — {% endif %}{{ params.partidaDistrito }}{% endif %}{% if doc.envio is not null and doc.envio.partida is not null and doc.envio.partida.ubigeo is not empty %} · Ubigeo {{ doc.envio.partida.ubigeo }}{% endif %}</div>
  </div>
  <div class="arrow">hacia →</div>
  <div class="leg right">
    <div class="k">Llegada</div>
    <div class="v">{% if doc.envio is not null and doc.envio.destino is not null %}{{ doc.envio.destino.direccion }}{% endif %}</div>
    <div class="a">{% if params.destinoDistrito is not empty %}{% if params.destinoDepartamento is not empty %}{{ params.destinoDepartamento }} — {{ params.destinoProvincia }} — {% endif %}{{ params.destinoDistrito }}{% endif %}{% if doc.envio is not null and doc.envio.destino is not null and doc.envio.destino.ubigeo is not empty %} · Ubigeo {{ doc.envio.destino.ubigeo }}{% endif %}</div>
  </div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Destinatario</div>
    {% if cl is not null %}
    <div class="name">{{ cl.nombre }}</div>
    <div class="row"><span class="k">{{ cl.tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ cl.numeroDocumentoIdentidad }}</span></div>
    {% endif %}
  </div>
  <div class="party">
    <div class="label">Documento relacionado</div>
    {% if doc.documentosRelacionados is not empty %}
    {% for rel in doc.documentosRelacionados %}
    <div class="row"><span class="k">{{ rel.tipoDocumento }}</span><span class="mono">{{ rel.serieNumero }}</span></div>
    {% endfor %}
    {% endif %}
  </div>
</div>

<div class="meta-grid">
  <div><div class="k">Inicio</div><div class="v">{% if doc.envio is not null and doc.envio.fechaTraslado is not null %}{{ doc.envio.fechaTraslado|date('d/m/Y') }}{% endif %}</div></div>
  <div><div class="k">Motivo</div><div class="v">{% if doc.envio is not null %}{{ doc.envio.tipoTraslado }} {{ doc.envio.tipoTraslado|catalog('20') }}{% endif %}</div></div>
  <div><div class="k">Modalidad</div><div class="v">{% if doc.envio is not null %}{{ doc.envio.tipoModalidadTraslado }} {{ doc.envio.tipoModalidadTraslado|catalog('18') }}{% endif %}</div></div>
  <div><div class="k">Peso · bultos</div><div class="v">{% if doc.envio is not null %}{{ doc.envio.pesoTotal }} {{ doc.envio.pesoTotalUnidadMedida }}{% if doc.envio.numeroDeBultos is not null %} · {{ doc.envio.numeroDeBultos }}{% endif %}{% endif %}</div></div>
  <div><div class="k">Estado de pago</div><div class="v">{% if params.estadoPago is not empty %}{{ params.estadoPago }}{% endif %}</div></div><div><div class="k">Nro. taquito</div><div class="v">{% if params.trackingNumber is not empty %}{{ params.trackingNumber }}{% endif %}</div></div><div><div class="k">Total</div><div class="v">{% if params.totalGuia is not empty %}{{ params.totalGuia|n_format }}{% endif %}</div></div>
</div>

<div class="section">
  <div class="section-title">Bienes a trasladar</div>
  <table class="items">
    <thead>
      <tr><th class="c-idx">#</th><th class="c-code">Código</th><th>Descripción</th><th class="c-unit">Und</th><th class="c-qty">Cant.</th></tr>
    </thead>
    <tbody>
      {% for det in doc.detalles %}
      <tr>
        <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
        <td class="c-code mono">{{ det.codigo }}</td>
        <td class="desc"><div class="main">{{ det.descripcion }}</div></td>
        <td class="c-unit">{{ det.unidadMedida }}</td>
        <td class="c-qty mono">{{ det.cantidad|q_format }}</td>
      </tr>
      {% endfor %}
    </tbody>
  {% if params.totalGuia is not empty and params.totalGuia > 0 %}<tfoot><tr><td colspan="99" style="text-align:right;padding:10px 12px;font-weight:700;">Monto total: S/ {{ params.totalGuia|n_format }}</td></tr></tfoot>{% endif %}
  </table>
</div>

<div class="twocol">
  <div class="block">
    <div class="head">Transporte</div>
    {% if doc.envio is not null and doc.envio.transportista is not null %}
    <div class="row"><span class="k">Transportista</span><span>{{ doc.envio.transportista.nombre }} · {{ doc.envio.transportista.numeroDocumentoIdentidad }}</span></div>
    {% if doc.envio.transportista.numeroRegistroMTC is not empty %}
    <div class="row"><span class="k">Registro MTC</span><span class="mono">{{ doc.envio.transportista.numeroRegistroMTC }}</span></div>
    {% endif %}
    {% endif %}
    {% if doc.subcontratado is not null %}
    <div class="row"><span class="k">Subcontratado</span><span>{{ doc.subcontratado.nombre }}{% if doc.subcontratado.numeroDocumentoIdentidad is not empty %} · {{ doc.subcontratado.numeroDocumentoIdentidad }}{% endif %}</span></div>
    {% endif %}
    {% if doc.envio is not null and doc.envio.vehiculo is not null %}
    <div class="row"><span class="k">Placa</span><span class="mono">{{ doc.envio.vehiculo.placa }}</span></div>
    {% if doc.envio.vehiculo.numeroCirculacion is not empty %}
    <div class="row"><span class="k">TUC/CHV</span><span class="mono">{{ doc.envio.vehiculo.numeroCirculacion }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.marca is not empty %}
    <div class="row"><span class="k">Marca</span><span>{{ doc.envio.vehiculo.marca }}</span></div>
    {% endif %}
    {% if doc.envio.vehiculo.modelo is not empty %}
    <div class="row"><span class="k">Modelo</span><span>{{ doc.envio.vehiculo.modelo }}</span></div>
    {% endif %}
    {% endif %}
  </div>
  <div class="block">
    <div class="head">Conductor</div>
    {% if doc.envio is not null and doc.envio.choferes is not empty %}
    <div class="row"><span class="k">Nombres</span><span>{{ doc.envio.choferes[0].nombres }} {{ doc.envio.choferes[0].apellidos }}</span></div>
    <div class="row"><span class="k">{{ doc.envio.choferes[0].tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ doc.envio.choferes[0].numeroDocumentoIdentidad }}</span></div>
    {% if doc.envio.choferes[0].licencia is not empty %}
    <div class="row"><span class="k">Brevete</span><span class="mono">{{ doc.envio.choferes[0].licencia }}</span></div>
    {% endif %}
    {% endif %}
  </div>
</div>

{% if doc.documentosRelacionados is not empty or doc.observaciones is not empty %}
<div class="related">
  {% if doc.documentosRelacionados is not empty %}
  <div class="block">
    <div class="head">Documentos relacionados</div>
    <div class="body">
      {% for rel in doc.documentosRelacionados %}
      <p>{{ rel.tipoDocumento }} · <span class="mono">{{ rel.serieNumero }}</span></p>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  {% if doc.observaciones is not empty %}
  <div class="block">
    <div class="head">Observaciones</div>
    <div class="body">
      {% for obs in doc.observaciones|split('\n') %}<p class="small">· {{ obs }}</p>{% endfor %}
    </div>
  </div>
  {% endif %}
</div>
{% endif %}

<div class="signs">
  <div class="box"><div class="role">Remitente</div><div class="meta">{% if cp is not null %}{{ cp.razonSocial }}{% endif %}</div></div>
  <div class="box"><div class="role">Conductor</div><div class="meta">{% if doc.envio is not null and doc.envio.choferes is not empty %}{{ doc.envio.choferes[0].nombres }} {{ doc.envio.choferes[0].apellidos }} · {{ doc.envio.choferes[0].tipoDocumentoIdentidad|catalogAttr('06','abreviatura') }} {{ doc.envio.choferes[0].numeroDocumentoIdentidad }}{% endif %}</div></div>
  <div class="box"><div class="role">Destinatario</div><div class="meta">{% if cl is not null %}{{ cl.nombre }}{% endif %}</div></div>
</div>

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}<img src="data:image/png;base64,{{ qrBase64 }}" alt="QR Code" />{% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la Guía de Remisión Remitente Electrónica.</p>
    <p>Verifique este documento en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> con el RUC del remitente y el número del comprobante.</p>
    <p style="margin-top:6px;">Firmante: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    {% if hashDocumento is not empty %}<p class="hash">Hash: {{ hashDocumento }}</p>{% endif %}
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">Documento válido</span>
    <div class="line">Emitido conforme a la RS SUNAT 271-2019. Consultable en el portal oficial.</div>
  </div>
</div>

</body>
</html>
