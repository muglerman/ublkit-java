<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
{% set cp = doc.emisor %}
{% set cl = doc.receptor %}
{% set mon = doc.moneda|catalog('021') %}
{% set sym = doc.moneda|catalogAttr('021','simbolo') %}
{% set name = doc.tipoComprobante|catalog('01') %}
<title>{{ doc.serie }}-{{ doc.numero|str_pad(8, '0', 'left') }} · {{ name }}</title>
<style>
  {{ fontStyle | raw }}
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  :root {
    --ink: #161411;
    --ink-2: #57524b;
    --ink-3: #8c857c;
    --paper: #fbfaf6;
    --rule: #161411;
    --line: #e6e2d9;
    --accent: #a8412f;
  }
  body {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    line-height: 1.5;
    color: var(--ink);
    background: var(--paper);
    width: 794px;
    min-height: 559px;
    padding: 48px 56px;
  }
  .mono { font-family: 'JetBrains Mono', monospace; font-variant-numeric: tabular-nums; }
  .serif { font-family: 'Newsreader', serif; }
  p { margin: 0; }

  .hero { text-align: center; padding-bottom: 22px; border-bottom: 1px solid var(--rule); }
  .hero .logo { width: 46px; height: 46px; margin: 0 auto 10px; color: var(--ink); }
  .hero .logo img { max-width: 46px; max-height: 46px; object-fit: contain; }
  .hero .co-name { font-family: 'Newsreader', serif; font-size: 22px; font-weight: 500; letter-spacing: 0.02em; }
  .hero .co-sub { font-size: 10px; color: var(--ink-2); margin-top: 3px; letter-spacing: 0.04em; }
  .hero .doc-kind { margin-top: 18px; font-family: 'Newsreader', serif; font-style: italic; font-size: 14px; color: var(--ink-2); }
  .hero .doc-num { margin-top: 4px; font-family: 'JetBrains Mono', monospace; font-size: 22px; font-weight: 500; letter-spacing: 0.03em; }

  .meta-grid { display: grid; grid-template-columns: repeat(4, 1fr); padding: 18px 0; border-bottom: 1px solid var(--line); }
  .meta-grid > div { padding: 0 14px; }
  .meta-grid > div + div { border-left: 1px solid var(--line); }
  .meta-grid .k { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--ink-3); margin-bottom: 3px; }
  .meta-grid .v { font-size: 11px; font-weight: 500; }

  .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; padding: 22px 0; border-bottom: 1px solid var(--line); }
  .party .label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--ink-3); margin-bottom: 6px; }
  .party .name { font-family: 'Newsreader', serif; font-size: 15px; font-weight: 500; margin-bottom: 6px; }
  .party .row { display: grid; grid-template-columns: 72px 1fr; font-size: 10px; padding: 1px 0; }
  .party .row .k { color: var(--ink-3); }

  .section { padding-top: 20px; }
  .section-title { font-family: 'Newsreader', serif; font-style: italic; font-size: 13px; color: var(--ink-2); margin-bottom: 10px; }

  .items { width: 100%; border-collapse: collapse; }
  .items thead th { font-size: 9px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-3); font-weight: 500; text-align: left; padding: 8px 10px 8px 0; border-bottom: 1px solid var(--rule); }
  .items tbody td { padding: 12px 10px 12px 0; border-bottom: 1px solid var(--line); vertical-align: top; font-size: 9px; }
  .items .c-idx { width: 28px; color: var(--ink-3); }
  .items .c-code { width: 86px; }
  .items .c-qty, .items .c-price, .items .c-tax, .items .c-unit { text-align: right; }
  .items .c-qty { width: 60px; }
  .items .c-unit { width: 48px; text-align: center; color: var(--ink-3); }
  .items .c-price { width: 82px; }
  .items .c-tax { width: 84px; padding-right: 0; }
  .items .desc .main { font-weight: 500; }
  .items .desc .sub { font-size: 9.5px; color: var(--ink-3); margin-top: 2px; }

  .bottom { display: grid; grid-template-columns: 1fr 300px; gap: 40px; margin-top: 22px; }
  .notes .block { margin-bottom: 14px; }
  .notes .block .head { font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--ink-3); margin-bottom: 3px; }
  .notes .block .body { font-size: 10px; }
  .notes .small { font-size: 9.5px; color: var(--ink-2); }
  .notes .block .body p + p { margin-top: 2px; }

  .totals .line { display: flex; justify-content: space-between; padding: 4px 0; font-size: 9px; }
  .totals .line .k { color: var(--ink-2); }
  .totals .line .v { font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
  .totals .rule { border-top: 1px solid var(--line); margin: 6px 0; }
  .totals .grand { display: flex; justify-content: space-between; align-items: baseline; padding: 12px 0 6px; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); margin-top: 6px; }
  .totals .grand .k { font-family: 'Newsreader', serif; font-style: italic; font-size: 14px; color: var(--ink-2); }
  .totals .grand .v { font-family: 'JetBrains Mono', monospace; font-size: 18px; font-weight: 600; white-space: nowrap; }
  .totals .in-words { margin-top: 10px; font-size: 9.5px; color: var(--ink-2); font-style: italic; text-align: right; }

  .foot { display: grid; grid-template-columns: 90px 1fr auto; gap: 22px; align-items: start; margin-top: 30px; padding-top: 18px; border-top: 1px solid var(--line); }
  .foot .qr { width: 90px; height: 90px; background: #fff; padding: 4px; border: 1px solid var(--line); }
  .foot .qr img { width: 100%; height: 100%; display: block; }
  .foot .meta { font-size: 9.5px; color: var(--ink-2); }
  .foot .meta strong { color: var(--ink); }
  .foot .meta .hash { font-family: 'JetBrains Mono', monospace; word-break: break-all; font-size: 8.5px; margin-top: 2px; color: var(--ink-3); }
  .foot .stamp { text-align: right; min-width: 180px; }
  .foot .stamp .badge { display: inline-block; color: var(--accent); padding: 4px 0; font-family: 'Newsreader', serif; font-style: italic; font-size: 13px; border-bottom: 1px solid var(--accent); }
  .foot .stamp .line { font-size: 9.5px; color: var(--ink-2); margin-top: 8px; max-width: 180px; }
</style>
</head>
<body>

<div class="hero">
  {% if params.logo is not empty %}<div class="logo"><img src="{{ params.logo }}" alt="logo"/></div>{% endif %}
  <div class="co-name">{{ doc.emisor.razonSocial }}</div>
  <div class="co-sub">{{ doc.emisor.direccion.direccion }} · RUC {{ doc.emisor.ruc }}{% if cp is not null and cp.contacto is not null %} · {{ cp.contacto.email }}{% endif %}</div>
  <div class="doc-kind">{{ name }}</div>
  <div class="doc-num">{{ doc.serie }} · {{ doc.numero|str_pad(8, '0', 'left') }}</div>
</div>

<div class="meta-grid">
  <div><div class="k">Emitido</div><div class="v">{{ doc.fechaEmision|date('d/m/Y') }}</div></div>
  <div><div class="k">Vencimiento</div><div class="v">{% if doc.fechaVencimiento is not null %}{{ doc.fechaVencimiento|date('d/m/Y') }}{% endif %}</div></div>
  <div><div class="k">Moneda</div><div class="v">{{ mon }}{% if doc.tipoCambio is not null %} · T/C {{ doc.tipoCambio.venta }}{% endif %}</div></div>
  <div><div class="k">Condición</div><div class="v">{% if doc.formaDePago is not null %}{{ doc.formaDePago.tipo }}{% if doc.formaDePago.cuotas is not empty %} · {{ doc.formaDePago.cuotas|length }} cuotas{% endif %}{% endif %}</div></div>
</div>

<div class="parties">
  <div class="party">
    <div class="label">Facturado a</div>
    <div class="name">{{ doc.receptor.nombre }}</div>
    <div class="row"><span class="k">{{ doc.receptor.tipoDocIdentidad|catalogAttr('06','abreviatura') }}</span><span class="mono">{{ doc.receptor.numDocIdentidad }}</span></div>
    <div class="row"><span class="k">Dirección</span><span>{{ doc.receptor.direccion.direccion }}</span></div>
    <div class="row"><span class="k">Ubicación</span><span>{% if cl is not null and cl.direccion is not null %}{{ cl.direccion.departamento }} · {{ cl.direccion.distrito }}{% endif %}</span></div>
    <div class="row"><span class="k">O/C</span><span class="mono">{{ doc.ordenDeCompra }}</span></div>
  </div>
  <div class="party">
    <div class="label">Operación</div>
    <div class="name serif">{{ doc.tipoOperacion }}{% if doc.tipoOperacion is not null %} — {{ doc.tipoOperacion | catalog('51') }}{% endif %}</div>
    <div class="row"><span class="k">Entrega</span><span>{% if doc.direccionEntrega is defined and doc.direccionEntrega is not null %}{{ doc.direccionEntrega.direccion }}{% endif %}</span></div>
    <div class="row"><span class="k">Guía</span><span class="mono">{% if doc.guias is not empty %}{% for guia in doc.guias %}{{ guia.serie }}-{{ guia.numero }}{% if not loop.last %}, {% endif %}{% endfor %}{% endif %}</span></div>
    <div class="row"><span class="k">Forma pago</span><span>{% if doc.formaDePago is not null %}{{ doc.formaDePago.tipo }}{% endif %}</span></div>
  </div>
</div>

<div class="section">
  <div class="section-title">Detalle</div>
  <table class="items">
    <thead>
      <tr><th class="c-idx">#</th><th class="c-code">Código</th><th>Descripción</th><th class="c-unit">Und</th><th class="c-qty">Cant.</th><th class="c-price">P. Unit.</th><th class="c-tax">Importe</th></tr>
    </thead>
    <tbody>

    {% for det in doc.detalles %}
    <tr>
      <td class="c-idx mono">{{ (loop.index + 1)|str_pad(2, '0', 'left') }}</td>
      <td class="c-code mono">{{ det.codigoProducto }}</td>
      <td class="desc"><div class="main">{{ det.descripcion }}</div><div class="sub">{% if det.codProductoSUNAT %}SUNAT {{ det.codigoProductoSunat }}{% endif %}</div></td>
      <td class="c-unit">{{ det.unidadMedida }}</td>
      <td class="c-qty mono">{{ det.cantidad|n_format }}</td>
      <td class="c-price mono">{{ det.precio|n_format }}</td>
      <td class="c-tax mono">{{ det.mtoValorVenta|n_format }}</td>
    </tr>
    {% endfor %}
  </tbody>
  </table>
</div>

<div class="bottom">
  <div class="notes">
    <div class="block"><div class="head">Condiciones de pago</div><div class="body">
      <p class="small">{% if doc.formaDePago is not null %}{{ doc.formaDePago.tipo }}{% endif %} · {{ sym }} {{ doc.totalImporte.importeConImpuestos|n_format }}</p>
      {% if doc.formaDePago is not null and doc.formaDePago.cuotas is not empty %}
        {% for cuota in doc.formaDePago.cuotas %}
          <p class="small">Cuota {{ loop.index + 1 }} · {{ cuota.fechaPago|date('d/m/Y') }} · {{ sym }} {{ cuota.monto|n_format }}</p>
        {% endfor %}
      {% endif %}
    </div></div>
    {% if doc.detraccion is not null %}
    <div class="block"><div class="head">Detracción</div><div class="body">
      <p>{{ sym }} {{ doc.detraccion.monto|n_format }} · {{ doc.detraccion.codigoBien }} - {{ doc.detraccion.codigoBien|catalog('54') }}</p>
      <p class="small">Medio: {{ doc.detraccion.medioPago|catalog('59') }} · BN {{ doc.detraccion.cuentaBanco }}</p>
    </div></div>
    {% endif %}
    {% if doc.observaciones %}
    <div class="block"><div class="head">Observaciones</div><div class="body">
      <p>{{ doc.observaciones }}</p>
    </div></div>
    {% endif %}
    <div class="block"><div class="head">Leyendas SUNAT</div><div class="body">
      {% if doc.leyendas is not empty %}{% for entry in doc.leyendas %}<p class="small">· {{ entry.value }}</p>{% endfor %}{% endif %}
    </div></div>
  </div>

  <div class="totals">
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.gravadoBaseImponible is not null %}
    <div class="line"><span class="k">Op. gravadas</span><span class="v">{{ sym }} {{ doc.totalImpuestos.gravadoBaseImponible|n_format }}</span></div>
    {% endif %}
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.exoneradoBaseImponible is not null %}
    <div class="line"><span class="k">Op. exoneradas</span><span class="v">{{ sym }} {{ doc.totalImpuestos.exoneradoBaseImponible|n_format }}</span></div>
    {% endif %}
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.inafectoBaseImponible is not null %}
    <div class="line"><span class="k">Op. inafectas</span><span class="v">{{ sym }} {{ doc.totalImpuestos.inafectoBaseImponible|n_format }}</span></div>
    {% endif %}
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.gratuitoBaseImponible is not null %}
    <div class="line"><span class="k">Op. gratuitas</span><span class="v">{{ sym }} {{ doc.totalImpuestos.gratuitoBaseImponible|n_format }}</span></div>
    {% endif %}
    <div class="rule"></div>
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.gravadoImporte is not null %}
    <div class="line"><span class="k">IGV (18%)</span><span class="v">{{ sym }} {{ doc.totalImpuestos.gravadoImporte|n_format }}</span></div>
    {% endif %}
    {% if doc.totalImpuestos is not null and doc.totalImpuestos.icbImporte is not null %}
    <div class="line"><span class="k">ICBPER</span><span class="v">{{ sym }} {{ doc.totalImpuestos.icbImporte|n_format }}</span></div>
    {% endif %}
    <div class="grand"><span class="k">Total</span><span class="v">{{ sym }} {{ doc.totalImporte.importeConImpuestos|n_format }}</span></div>
    <div class="in-words">{{ doc.leyendas['1000'] }}</div>
  </div>
</div>

<div class="foot">
  <div class="qr">
    {% if qrBase64 is not empty %}<img src="data:image/png;base64,{{ qrBase64 }}" alt="QR Code" />{% endif %}
  </div>
  <div class="meta">
    <p><strong>Representación impresa</strong> de la {{ name }} Electrónica.</p>
    <p>Verifique este documento en <strong>{{ params.consultaUrl|default('sunat.gob.pe') }}</strong> con el RUC del emisor y el número del comprobante.</p>
    <p style="margin-top:6px;">Firmante: {% if cp is not null %}{{ cp.ruc }} · {{ cp.razonSocial }}{% endif %}</p>
    <p class="hash">Hash: {{ hashDocumento }}</p>
    {% if params.footer is not null %}<p id="custom-footer-box" style="margin-top:10px; font-style:italic;">{{ params.footer }}</p>{% endif %}
  </div>
  <div class="stamp">
    <span class="badge">Documento válido</span>
    <div class="line">Emitido conforme al RCP SUNAT. Consultable en el portal oficial.</div>
  </div>
</div>

</body>
</html>
