					<leftPen lineWidth="0.7"/>
					<bottomPen lineWidth="0.7"/>
					<rightPen lineWidth="0.7"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="7"/>
				</textElement>
				<textFieldExpression><![CDATA[($F{tipoGuia} == "31"
? "REPRESENTACION IMPRESA DE LA GUIA DE REMISION TRANSPORTISTA."
: "REPRESENTACION IMPRESA DE LA GUIA DE REMISION REMITENTE.") + " PODRA CONSULTARLA EN CLAVE SOL." ]]></textFieldExpression>
			</textField>
		</band>
	</pageFooter>
</jasperReport>
